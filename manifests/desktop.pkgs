# desktop.pkgs — r130 fat/offline desktop seed (arm64)
#
# Seed for build/build-desktop-mirror.sh: the explicit set of desktop packages
# whose full dependency closure is downloaded from ports.ubuntu.com into
# build/desktop-mirror/ and embedded in the ISO pool. This reverses the old
# "server-only mirror, desktop installs ONLINE" policy (post-install/20-desktop.sh)
# so the desktop layer installs fully offline from file:///cdrom and never stalls
# on a slow/unreachable Ubuntu mirror (the r129 14% / 20-desktop stall).
#
# This list MUST be a superset of everything post-install/20-desktop.sh installs,
# so the bundled pool carries the full closure of the installed desktop.
# Names only (one per line); apt resolves the dependency closure. Component of
# origin (main/universe) is irrelevant — everything is repackaged into our single
# 'main' offline component.

# --- curated Sky1 core (XFCE + LightDM + Xorg fbdev + xrdp + GL) ---
lightdm
lightdm-gtk-greeter
xubuntu-core
xfce4-session
xfce4-terminal
xfce4-power-manager
xfce4-screenshooter
xfce4-taskmanager
xserver-xorg-video-fbdev
xserver-xorg-video-modesetting
xrdp
mesa-utils
vulkan-tools
libglu1-mesa

# --- audio (PipeWire + Pulse shim + WirePlumber + control) ---
pipewire
pipewire-pulse
pipewire-alsa
wireplumber
pavucontrol
xfce4-pulseaudio-plugin

# --- removable media / disks ---
gvfs
gvfs-backends
udisks2
gnome-disk-utility

# --- network applet ---
network-manager-gnome

# --- bluetooth (Sky1 MT7922) ---
bluez
blueman

# --- fonts (Noto base + CJK + colour emoji) ---
fonts-noto-core
fonts-noto-cjk
fonts-noto-color-emoji

# --- archives ---
xarchiver
thunar-archive-plugin
7zip
unrar-free

# --- core apps (PDF / media / image / text) ---
evince
mpv
ristretto
mousepad

# --- panel UX (Whisker menu + clipboard) ---
xfce4-whiskermenu-plugin
xfce4-clipman-plugin

# --- screensaver (2D only; GL hacks shimmed/removed at install) ---
xscreensaver
xscreensaver-data
xscreensaver-data-extra
x11-utils

# --- r130 bucket: desktop completeness (Xubuntu defaults cix lacked) ---
catfish
menulibre
mugshot
gigolo
xfce4-panel-profiles
baobab
gnome-system-monitor
gnome-font-viewer
seahorse
xfce4-dict
xfce4-cpugraph-plugin
xfce4-netload-plugin
xfce4-systemload-plugin
xfce4-weather-plugin
xfce4-places-plugin
xfce4-verve-plugin
xfce4-xkb-plugin

# --- r130 bucket: offline-apt management tools ---
synaptic
gdebi
gdebi-core
software-properties-gtk

# --- r130 bucket: image editing ---
gimp

# --- r130.4 bucket: cix-gstreamer runtime deps (bundle so it force-configures
#     cleanly offline). The vendor deb declares Debian-style libxml2 /
#     libjpeg62-turbo (absent on Ubuntu); the runtime .so's ship under the
#     Ubuntu names libxml2-16 / libjpeg-turbo8, plus the over-broad multi-GPU
#     libdrm-* family it pulls in. ---
libxml2-16
libjpeg-turbo8
libva-glx2
libwayland-bin
libnice10
libdrm-radeon1
libdrm-nouveau2
libdrm-freedreno1
libdrm-tegra0
libdrm-etnaviv1

# --- r130.4 bucket: desktop apps 20-desktop installs that were missing from
#     the offline pool (App Center, Flatpak/portal stack, browsers, tweaks) ---
flatpak
gnome-software
gnome-software-plugin-flatpak
gnome-tweaks
gnome-session-canberra
xdg-desktop-portal-gtk
epiphany-browser
falkon
feh

# --- r130.4 bucket: GPU/Vulkan validation + benchmark tools 47-llm-stack +
#     16-mesa request (glmark2 is split on Ubuntu: -x11 / -es2-x11 variants;
#     the bare glmark2 / glmark2-es2 names do not exist) ---
vulkan-validationlayers
clinfo
glmark2-x11
glmark2-es2-x11
glmark2-es2-wayland
glmark2-wayland
glslc

# --- r130.4 bucket: agents + system utilities (nodejs/npm for ncz agents,
#     podman DNS, syslog, dialog UI, SVG rasteriser) ---
nodejs
npm
whiptail
rsyslog
librsvg2-bin
aardvark-dns

# --- r130.4 bucket: Plymouth boot splash theme + asset tooling ---
plymouth-theme-spinner
imagemagick
