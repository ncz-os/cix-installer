     1	#!/bin/bash
     2	# 72-rescue-partition.sh — populate the r130 dedicated RESCUE PARTITION.
     3	#
     4	# The partman recipe in preseed-ubuntu.cfg creates a 4 GiB ext4 partition
     5	# (NCZRESCUE) with NO mountpoint on the main system. This hook fills it with
     6	# the pre-built rescue rootfs (assets/rescue/rescue-rootfs.tar.zst) and the
     7	# EDGE kernel payload, then records a readiness marker.
     8	#
     9	# IMPORTANT — division of labour with 70-bootloader.sh:
    10	#   This hook runs in Phase 2 (numbered hooks). 70-bootloader.sh runs LATER,
    11	#   in run-all.sh's EXIT trap, and rewrites the ESP refind.conf + staged
    12	#   vmlinuz-* every run. So the rEFInd "RESCUE PARTITION" menuentry is written
    13	#   by 70-bootloader.sh (the sole ESP owner), gated on the RESCUE_READY marker
    14	#   this hook leaves behind. Here we only touch the rescue PARTITION (never the
    15	#   ESP), so nothing we do gets clobbered.
    16	#
    17	# Edge kernel = the same byte-identical payload the main system runs
    18	# (assets/kernel/edge), so the rescue env exercises live silicon.
    19	set -uo pipefail   # NOT -e: optional Phase-2 hook, must fail soft
    20	
    21	INSTALLER_META=/usr/local/lib/cix-installer
    22	ASSETS_KERNEL="$INSTALLER_META/assets/kernel"
    23	RESCUE_ASSETS="$INSTALLER_META/assets/rescue"
    24	TARBALL="$RESCUE_ASSETS/rescue-rootfs.tar.zst"
    25	MNT=/mnt/ncz-rescue
    26	MARKER="$INSTALLER_META/RESCUE_READY"
    27	
    28	echo "[72] rescue partition population"
    29	
    30	# --- preconditions (skip soft) ---
    31	KVER_NEXT=""
    32	[ -f "$INSTALLER_META/KVER_NEXT" ] && KVER_NEXT=$(cat "$INSTALLER_META/KVER_NEXT" 2>/dev/null || true)
    33	if [ -z "$KVER_NEXT" ]; then
    34	    echo "[72] no edge (NEXT) kernel staged — rescue partition uses edge kernel; skipping"
    35	    exit 0
    36	fi
    37	if [ ! -f "$TARBALL" ]; then
    38	    echo "[72] $TARBALL not present (run build/build-rescue-rootfs.sh at bake time) — skipping"
    39	    exit 0
    40	fi
    41	if [ ! -f "$ASSETS_KERNEL/edge/Image-cixmini.bin" ] || [ ! -f "$ASSETS_KERNEL/edge/modules-cixmini.tgz" ]; then
    42	    echo "[72] edge kernel assets missing under $ASSETS_KERNEL/edge — skipping"
    43	    exit 0
    44	fi
    45	for t in blkid lsblk findmnt zstd tar depmod mkfs.ext4 e2label; do
    46	    command -v "$t" >/dev/null 2>&1 || { echo "[72] missing tool $t — skipping rescue partition"; exit 0; }
    47	done
    48	
    49	# --- locate the rescue partition ---
    50	ROOT_SRC=$(findmnt -no SOURCE / 2>/dev/null || true)
    51	ESP_SRC=$(findmnt -no SOURCE /boot/efi 2>/dev/null || true)
    52	echo "[72] root=$ROOT_SRC  esp=$ESP_SRC"
    53	
    54	RESCUE_SRC=$(blkid -L NCZRESCUE 2>/dev/null || true)
    55	if [ -z "$RESCUE_SRC" ]; then
    56	    # by GPT partition label
    57	    RESCUE_SRC=$(lsblk -rno NAME,PARTLABEL 2>/dev/null | awk '$2=="NCZRESCUE"{print "/dev/"$1}' | head -1)
    58	fi
    59	if [ -z "$RESCUE_SRC" ] && [ -n "$ROOT_SRC" ]; then
    60	    # by elimination: a partition on the root disk that is neither / nor ESP
    61	    DISK=$(lsblk -no PKNAME "$ROOT_SRC" 2>/dev/null | head -1)
    62	    if [ -n "$DISK" ]; then
    63	        for p in $(lsblk -rno NAME,TYPE "/dev/$DISK" 2>/dev/null | awk '$2=="part"{print "/dev/"$1}'); do
    64	            [ "$p" = "$ROOT_SRC" ] && continue
    65	            [ "$p" = "$ESP_SRC" ] && continue
    66	            RESCUE_SRC="$p"
    67	            break
    68	        done
    69	    fi
    70	fi
    71	if [ -z "$RESCUE_SRC" ] || [ ! -b "$RESCUE_SRC" ]; then
    72	    echo "[72] no rescue partition found (no NCZRESCUE, no spare partition) — skipping"
    73	    echo "      block devices:"; lsblk 2>&1 | sed 's/^/        /' | head -20
    74	    exit 0
    75	fi
    76	echo "[72] rescue partition = $RESCUE_SRC"
    77	
    78	# Guard: never clobber the live root or ESP.
    79	if [ "$RESCUE_SRC" = "$ROOT_SRC" ] || [ "$RESCUE_SRC" = "$ESP_SRC" ]; then
    80	    echo "[72] refusing to use $RESCUE_SRC (it is the live root or ESP) — skipping"
    81	    exit 0
    82	fi
    83	
    84	# --- ensure ext4 + label ---
    85	FST=$(blkid -s TYPE -o value "$RESCUE_SRC" 2>/dev/null || true)
    86	if [ "$FST" != "ext4" ]; then
    87	    echo "[72] $RESCUE_SRC is '$FST' — formatting ext4 (NCZRESCUE)"
    88	    mkfs.ext4 -F -L NCZRESCUE "$RESCUE_SRC" || { echo "[72] mkfs failed — skipping"; exit 0; }
    89	else
    90	    e2label "$RESCUE_SRC" NCZRESCUE 2>/dev/null || true
    91	fi
    92	
    93	# --- mount + extract rootfs ---
    94	mkdir -p "$MNT"
    95	umount "$MNT" 2>/dev/null || true
    96	if ! mount "$RESCUE_SRC" "$MNT"; then
    97	    echo "[72] mount $RESCUE_SRC failed — skipping"; exit 0
    98	fi
    99	
   100	echo "[72] extracting rescue rootfs -> $MNT"
   101	if ! zstd -dc "$TARBALL" | tar -xpf - -C "$MNT" --numeric-owner; then
   102	    echo "[72] rootfs extract failed — unmounting + skipping"
   103	    umount "$MNT" 2>/dev/null || true
   104	    exit 0
   105	fi
   106	
   107	# --- install EDGE kernel + modules into the rescue rootfs ---
   108	# Modules MUST go in via --keep-directory-symlink (never plain -C /): the
   109	# tarball carries a top-level lib/ entry, and on a usrmerge rootfs /lib is a
   110	# symlink to usr/lib. A naive extract would clobber that symlink and orphan
   111	# ld-linux — the exact failure mode this rescue env exists to repair.
   112	echo "[72] installing edge kernel $KVER_NEXT into rescue rootfs"
   113	install -D -m 0644 "$ASSETS_KERNEL/edge/Image-cixmini.bin" "$MNT/boot/vmlinuz-$KVER_NEXT"
   114	tar xzf "$ASSETS_KERNEL/edge/modules-cixmini.tgz" -C "$MNT/usr" --strip-components=0 --keep-directory-symlink
   115	if [ ! -d "$MNT/usr/lib/modules/$KVER_NEXT" ]; then
   116	    echo "[72] WARN: modules tarball did not produce $MNT/usr/lib/modules/$KVER_NEXT"
   117	    ls "$MNT/usr/lib/modules/" 2>&1 | sed 's/^/        /'
   118	else
   119	    MODC=$(find "$MNT/usr/lib/modules/$KVER_NEXT" -name '*.ko*' 2>/dev/null | wc -l)
   120	    echo "[72] $MODC modules staged; running depmod"
   121	    depmod -b "$MNT" "$KVER_NEXT" 2>/dev/null || echo "[72] WARN: depmod returned non-zero"
   122	fi
   123	
   124	# initrd: reuse the main system's edge initrd (generic; mounts root=PARTUUID).
   125	# 70-bootloader.sh stages the ESP copy; this in-rootfs copy is for completeness.
   126	if [ -s "/boot/initrd.img-$KVER_NEXT" ]; then
   127	    install -D -m 0644 "/boot/initrd.img-$KVER_NEXT" "$MNT/boot/initrd.img-$KVER_NEXT"
   128	fi
   129	
   130	# --- AGENTS.md (refresh from asset if present) ---
   131	if [ -f "$RESCUE_ASSETS/AGENTS.md" ]; then
   132	    install -m 0644 "$RESCUE_ASSETS/AGENTS.md" "$MNT/AGENTS.md"
   133	    install -D -m 0644 "$RESCUE_ASSETS/AGENTS.md" "$MNT/root/AGENTS.md"
   134	    echo "[72] AGENTS.md refreshed in rescue rootfs"
   135	fi
   136	
   137	# --- verify the usrmerge /lib symlink survived ---
   138	if [ -L "$MNT/lib" ]; then
   139	    echo "[72] OK: rescue /lib -> $(readlink "$MNT/lib") (usrmerge symlink intact)"
   140	else
   141	    echo "[72] WARN: rescue /lib is not a symlink — running fixlib"
   142	    [ -x "$MNT/usr/local/sbin/ncz-rescue-fixlib" ] && chroot "$MNT" /usr/local/sbin/ncz-rescue-fixlib / 2>/dev/null || true
   143	fi
   144	
   145	# --- readiness marker for 70-bootloader.sh ---
   146	RP_PARTUUID=$(blkid -s PARTUUID -o value "$RESCUE_SRC" 2>/dev/null || true)
   147	{
   148	    echo "PARTUUID=$RP_PARTUUID"
   149	    echo "KVER=$KVER_NEXT"
   150	    echo "DEV=$RESCUE_SRC"
   151	} > "$MARKER"
   152	echo "[72] wrote marker $MARKER (PARTUUID=$RP_PARTUUID)"
   153	
   154	# --- finish: sync, unmount, reclaim space ---
   155	sync
   156	umount "$MNT" 2>/dev/null || true
   157	rm -f "$TARBALL" 2>/dev/null || true   # reclaim ~hundreds of MB on the main root
   158	echo "[72] rescue partition ready — 70-bootloader.sh will add the loader entry"
   159	exit 0

codex
Reviewed only; I did not modify files.

**A. Splash Hang**
Confirmed for the visible hang: [60-plymouth.sh](/home/jasonperlow/cix-installer-build/cix-installer/post-install/60-plymouth.sh:86) now reaches:

```sh
systemctl mask plymouth-quit.service plymouth-quit-wait.service
```

because `apt-get install plymouth plymouth-theme-spinner imagemagick` now succeeds. `plymouth-quit.service` is the unit that runs `plymouth quit`; masking it can leave the splash alive indefinitely.

Partial refute: that alone does not prove the machine never reached networked multi-user. A masked wanted unit normally fails its own job, not the whole target. So it cleanly explains “stuck at splash”; the “no ping” may be hidden by the splash, or may be the separate network profile gap below.

Minimal patch:

```diff
diff --git a/post-install/60-plymouth.sh b/post-install/60-plymouth.sh
@@
-# Mask plymouth-quit if it keeps failing (cosmetic, doesn't affect boot)
-# r51 saw "plymouth-quit.service Failed to start" in journal. Disable cleanly.
-systemctl mask plymouth-quit.service plymouth-quit-wait.service 2>/dev/null || true
-
-echo "[60] plymouth splash configured (or fallback) + plymouth-quit.service masked"
+# r130.6: ensure any older image that masked these units is repaired.
+# plymouth-quit.service is what tears down the splash before display-manager handoff.
+systemctl unmask plymouth-quit.service plymouth-quit-wait.service 2>/dev/null || true
+
+echo "[60] plymouth splash configured (or fallback) + plymouth-quit.service unmasked"
```

**B. Watermark At Bottom**
Confirmed. The resolute `plymouth-theme-spinner` package ships `spinner.plymouth` with:

```ini
WatermarkHorizontalAlignment=.5
WatermarkVerticalAlignment=.96
```

`.96` is intentionally bottom. The correct two-step key is `WatermarkVerticalAlignment`. Use a small top margin, symmetric with stock bottom:

```diff
diff --git a/post-install/60-plymouth.sh b/post-install/60-plymouth.sh
@@
 if grep -qE '^BackgroundEndColor=' "$SPIN_PLY"; then
     sed -i -E 's/^BackgroundEndColor=.*/BackgroundEndColor=0x0b0f14/' "$SPIN_PLY"
 else
     printf 'BackgroundEndColor=0x0b0f14\n' >> "$SPIN_PLY"
 fi
+if grep -qE '^WatermarkVerticalAlignment=' "$SPIN_PLY"; then
+    sed -i -E 's/^WatermarkVerticalAlignment=.*/WatermarkVerticalAlignment=.04/' "$SPIN_PLY"
+else
+    printf 'WatermarkVerticalAlignment=.04\n' >> "$SPIN_PLY"
+fi
```

**C. Ethernet**
Your `33-network.sh` fix is correct for the confirmed old root cause: it makes NM stop treating the d-i-installed NIC as ifupdown-owned by flipping `[ifupdown] managed=true` and rewriting `/etc/network/interfaces` to loopback-only at [33-network.sh](/home/jasonperlow/cix-installer-build/cix-installer/post-install/33-network.sh:71).

But there is a real remaining gap: the netplan file only says `renderer: NetworkManager`; it does not create a wired DHCP profile. NM usually creates an automatic wired profile, but not if `no-auto-default` state/config exists or if the device appears after first boot in a way NM does not auto-profile. Masking `systemd-networkd` is fine only if NM has a profile or auto-default works.

Minimal hardening:

```diff
diff --git a/post-install/33-network.sh b/post-install/33-network.sh
@@
 network:
   version: 2
   renderer: NetworkManager
+  ethernets:
+    ncz-wired-en:
+      match:
+        name: "en*"
+      dhcp4: true
+      dhcp6: true
+      optional: true
+    ncz-wired-eth:
+      match:
+        name: "eth*"
+      dhcp4: true
+      dhcp6: true
+      optional: true
 YAML
```

