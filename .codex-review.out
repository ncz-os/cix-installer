   538	        echo "    options \"$NEXT_OPTIONS\""
   539	        echo "}"
   540	        echo
   541	    fi
   542	    if [ -n "$RESCUE_PIN" ]; then
   543	        echo "menuentry \"NCZ-OS 26.6  ·  rescue — $RESCUE_PIN (safe: no NPU/GPU/VPU/KMS)\" {"
   544	        echo "    loader  /vmlinuz-$RESCUE_PIN"
   545	        [ -n "$REFIND_ICON" ] && echo "    icon    $REFIND_ICON"
   546	        [ "$RESCUE_HAS_INITRD" = "1" ] && echo "    initrd  /initrd.img-$RESCUE_PIN"
   547	        echo "    options \"$RESCUE_OPTIONS\""
   548	        echo "}"
   549	        echo
   550	    fi
   551	    # r130: dedicated on-disk RESCUE PARTITION (separate rootfs, edge kernel,
   552	    # full toolset). Reuses the staged edge kernel/initrd; only root= differs.
   553	    if [ -n "$RESCUEPART_OPTIONS" ]; then
   554	        echo "menuentry \"NCZ-OS 26.6  ·  RESCUE PARTITION — edge $KVER_NEXT, full toolset (telnet/dropbear/ssh)\" {"
   555	        echo "    loader  /vmlinuz-$KVER_NEXT"
   556	        [ -n "$REFIND_ICON" ] && echo "    icon    $REFIND_ICON"
   557	        [ "$NEXT_INITRD_AVAILABLE" = "1" ] && echo "    initrd  /initrd.img-$KVER_NEXT"
   558	        echo "    options \"$RESCUEPART_OPTIONS\""
   559	        echo "}"
   560	        echo
   561	    fi
   562	} > "$REFIND_CONF"

