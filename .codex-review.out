   458	# rEFInd resolves it by bare filename. Optional — if the asset is absent we
   459	# simply omit the `banner` directive (rEFInd falls back to its built-in art).
   460	BANNER_SRC="$INSTALLER_META/assets/refind/ncz-banner.png"
   461	REFIND_BANNER=""
   462	if [ -s "$BANNER_SRC" ]; then
   463	    install -m 0644 "$BANNER_SRC" /boot/efi/EFI/BOOT/ncz-banner.png
   464	    REFIND_BANNER="ncz-banner.png"
   465	    echo "  rEFInd banner installed → /boot/efi/EFI/BOOT/ncz-banner.png"
   466	else
   467	    echo "  note: rEFInd banner asset absent ($BANNER_SRC) — using default rEFInd art"
   468	fi
   469	
   470	# r128: NCZ tile icon for each menu entry (replaces rEFInd's generic Linux
   471	# glyph). Installed next to refind.conf so a bare `icon ncz.png` resolves.
   472	ICON_SRC="$INSTALLER_META/assets/refind/ncz.png"
   473	REFIND_ICON=""
   474	if [ -s "$ICON_SRC" ]; then
   475	    install -m 0644 "$ICON_SRC" /boot/efi/EFI/BOOT/ncz.png
   476	    REFIND_ICON="ncz.png"
   477	    echo "  rEFInd entry icon installed → /boot/efi/EFI/BOOT/ncz.png"
   478	fi
   479	
   480	# r128: rEFInd's standard icons/ directory MUST exist next to refind.conf, or
   481	# rEFInd silently falls back to TEXT-ONLY mode (no banner, no graphical menu) —
   482	# this is documented rEFInd behaviour and was why the NCZ-OS 26.6 banner did
   483	# not paint on Sky1. Installing it enables the graphical boot menu.
   484	ICONS_SRC="$INSTALLER_META/assets/refind/icons"
   485	if [ -d "$ICONS_SRC" ]; then
   486	    rm -rf /boot/efi/EFI/BOOT/icons
   487	    cp -a "$ICONS_SRC" /boot/efi/EFI/BOOT/icons
   488	    echo "  rEFInd icons/ installed → /boot/efi/EFI/BOOT/icons ($(ls /boot/efi/EFI/BOOT/icons 2>/dev/null | wc -l | tr -d ' ') files)"
   489	else
   490	    echo "  WARN: rEFInd icons/ asset absent ($ICONS_SRC) → menu will render TEXT-ONLY (no banner)"
   491	fi
   492	
   493	# default_selection matches a substring of the menu-entry title. edge is the
   494	# default when staged, else stable. rescue is always manual-only.
   495	if [ "$NEXT_AVAILABLE" = "1" ]; then
   496	    DEFAULT_TOKEN="edge"
   497	else
   498	    DEFAULT_TOKEN="stable"
   499	fi
   500	
   501	# refind.conf lives next to the binary; rEFInd resolves loader/initrd paths
   502	# from the volume (ESP) root, where we staged the kernels.
   503	REFIND_CONF=/boot/efi/EFI/BOOT/refind.conf
   504	{
   505	    echo "# rEFInd — NCZ cixmini $BUILD_VERSION (generated by 70-bootloader.sh)"
   506	    echo "# Kernels live on the FAT ESP; each kernel's initramfs mounts the"
   507	    echo "# $ROOT_FSTYPE root. No btrfs/ext4 EFI driver is required."
   508	    echo "timeout 10"
   509	    echo "log_level 0"
   510	    echo "use_nvram false"
   511	    # r128: force a graphical GOP mode. Without this the Sky1 firmware can leave
   512	    # rEFInd rendering text-only; `resolution max` selects the largest reported
   513	    # GOP mode and locks in graphics so the NCZ-OS 26.6 banner + icons paint.
   514	    echo "resolution max"
   515	    [ -n "$REFIND_BANNER" ] && echo "banner $REFIND_BANNER"
   516	    # fillscreen makes the NCZ-OS 26.6 art the full menu background (not a
   517	    # small top strip), so the whole rEFInd main menu is branded.
   518	    [ -n "$REFIND_BANNER" ] && echo "banner_scale fillscreen"
   519	    echo "showtools shell,reboot,shutdown,firmware"
   520	    echo "scanfor manual"
   521	    echo "scan_all_linux_kernels false"
   522	    echo "default_selection \"$DEFAULT_TOKEN\""
   523	    echo
   524	    if [ "$LTS_AVAILABLE" = "1" ]; then
   525	        echo "menuentry \"NCZ-OS 26.6  ·  stable — kernel $KVER_LTS (LTS 6.18)\" {"
   526	        echo "    loader  /vmlinuz-$KVER_LTS"
   527	        [ -n "$REFIND_ICON" ] && echo "    icon    $REFIND_ICON"
   528	        [ "$LTS_INITRD_AVAILABLE" = "1" ] && echo "    initrd  /initrd.img-$KVER_LTS"
   529	        echo "    options \"$LTS_OPTIONS\""
   530	        echo "}"
   531	        echo
   532	    fi
   533	    if [ "$NEXT_AVAILABLE" = "1" ]; then
   534	        echo "menuentry \"NCZ-OS 26.6  ·  edge — kernel $KVER_NEXT (NEXT 7.0.x) [DEFAULT/BETA]\" {"
   535	        echo "    loader  /vmlinuz-$KVER_NEXT"
   536	        [ -n "$REFIND_ICON" ] && echo "    icon    $REFIND_ICON"
