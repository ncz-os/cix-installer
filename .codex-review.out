   112	# NetworkManager-wait-online.service masked (a boot-speed default),
   113	# which silently neutralises every "After=network-online.target"
   114	# ordering: timer/oneshot units (e.g. nclawzero-load-agent-images)
   115	# then fire before DHCP/link is up and fail at boot. Unmask + enable
   116	# so network-online.target actually waits for NM. This is bounded by
   117	# NM_ONLINE_TIMEOUT (~30s) and never blocks login/ssh, which are gated
   118	# on network.target (link present), not network-online.target.
   119	systemctl unmask NetworkManager-wait-online.service 2>/dev/null || true
