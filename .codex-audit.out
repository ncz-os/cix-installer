build/70-bootloader.sh:193:options $LTS_OPTIONS
build/70-bootloader.sh:197:    echo "  skipping cixmini-lts.conf (LTS kernel not installed)"
build/70-bootloader.sh:201:# Entry — cixmini-lts-safe.conf (SAFE GRAPHICS — 6.18 LTS, accelerators off)
build/70-bootloader.sh:203:# Boots the 6.18 LTS (CIX BSP) kernel but module_blacklists the heavy Sky1
build/70-bootloader.sh:204:# accelerator / display / audio / codec drivers that are the usual culprits
build/70-bootloader.sh:205:# for boot hangs (NPU, GPU, the Sky1 DPU/DP, VPUs, DSP, HDA/SOF audio).
build/70-bootloader.sh:206:# With no KMS driver bound, video falls back to the UEFI framebuffer
build/70-bootloader.sh:208:# load normally. Reuses the LTS kernel binary — no extra ESP space. Use this
build/70-bootloader.sh:209:# when a full boot wedges during GPU/display/NPU/DSP bring-up.
build/70-bootloader.sh:211:if [ "$LTS_AVAILABLE" = "1" ]; then
build/70-bootloader.sh:214:    # The base cmdline already carries a module_blacklist= (typec). The kernel
build/70-bootloader.sh:215:    # honors only ONE module_blacklist= (last wins), so MERGE our list into the
build/70-bootloader.sh:217:    if [[ "$MARTJOHNSON_CMDLINE" == *module_blacklist=* ]]; then
build/70-bootloader.sh:218:        SAFE_CMDLINE="${MARTJOHNSON_CMDLINE/module_blacklist=/module_blacklist=$SAFE_BLACKLIST,}"
build/70-bootloader.sh:220:        SAFE_CMDLINE="$MARTJOHNSON_CMDLINE module_blacklist=$SAFE_BLACKLIST"
build/70-bootloader.sh:224:    cat > /boot/efi/loader/entries/cixmini-lts-safe.conf <<EOF
