   162	
   163	# ----------------------------------------------------------------------
   164	# Discover root partition by PARTUUID
   165	#
   166	# r121 btrfs fix: on a btrfs root installed into a subvolume (d-i
   167	# partman-btrfs uses @rootfs), `findmnt -no SOURCE /` returns the device
   168	# WITH the subvolume bracket, e.g. "/dev/nvme0n1p2[/@rootfs]". Passing that
   169	# to blkid makes blkid exit 2 ("device not found"), which under
   170	# `set -euo pipefail` aborted 70-bootloader -> run-all -> late.sh with the
   171	# red "preseeded command failed (exit 2)" dialog. `--nofsroot` strips the
   172	# [/subvol] suffix so blkid sees the bare partition device.
   173	# ----------------------------------------------------------------------
   174	ROOT_SRC=$(findmnt -no SOURCE --nofsroot /)
   175	ROOT_PARTUUID=$(blkid -s PARTUUID -o value "$ROOT_SRC")
   176	ROOT_FSTYPE=$(findmnt -no FSTYPE /)
   177	# btrfs subvolume (e.g. /@rootfs) -> rootflags=subvol=@rootfs so the kernel
   178	# mounts the installed subvolume, not the btrfs top-level. Empty / "/" means
   179	# the root is the top-level volume and no rootflags is needed.
   180	ROOT_SUBVOL=""
   181	if [ "$ROOT_FSTYPE" = "btrfs" ]; then
   182	    ROOT_FSROOT=$(findmnt -no FSROOT / 2>/dev/null || echo "/")
   183	    case "$ROOT_FSROOT" in
   184	        ""|"/") ROOT_SUBVOL="" ;;
   185	        *)      ROOT_SUBVOL="${ROOT_FSROOT#/}" ;;
   186	    esac
   187	fi
   188	echo "  root source=$ROOT_SRC PARTUUID=$ROOT_PARTUUID fstype=$ROOT_FSTYPE subvol=${ROOT_SUBVOL:-(none)}"
   189	
   190	# ----------------------------------------------------------------------
   191	# Cmdline (MartJohnson 2026-04-30 working set for MS-R1, both LTS+NEXT)
   192	#
   193	#   loglevel=4                          — visible kernel msgs through boot
   194	#   console=tty0 console=ttyAMA2,115200 — HDMI primary + serial mirror
   195	#   efi=noruntime                       — disable buggy MS-R1 EFI runtime services
   196	#   acpi=force                          — bypass DSDT preference checks
   197	#   arm-smmu-v3.disable_bypass=0        — SMMUv3 IORT compatibility
   198	#   audit_backlog_limit=8192            — early-boot audit subsystem doesn't drop msgs
   199	#   clk_ignore_unused                   — Cix Sky1 SCMI requires this
   200	#   keep_bootcon                        — early console persists through handoff
   201	#   panic=30                            — 30s grace before reboot on panic
   202	#
   203	# NPU is config-disabled in MartJohnson configs (CONFIG_ARMCHINA_NPU=n)
   204	# so cmdline module_blacklist=armchina_npu is unnecessary. We don't
   205	# add module blacklists here — the configs already disable everything
   206	# that would cause boot trouble on MS-R1.
   207	# ----------------------------------------------------------------------
   208	# r75 Codex round-5 HIGH fix — per-entry cmdline split.
   209	#
   210	# LTS keeps efi=noruntime (r74 ship stability; original MS-R1 EFI
   211	# runtime quirk worked around by disabling it). NEXT drops it because
   212	# systemd-bless-boot requires EFI runtime variables (LoaderBootCountPath)
   213	# to mark a successful boot as good — without that, repeated successful
   214	# NEXT boots burn the +N-M counter to .failed and roll back to LTS.
   215	# linux-cix-sky1-next 7.0.x has newer EFI handling than the 6.6 fork
   216	# the noruntime workaround was originally added for; defaulting to
   217	# runtime-enabled on NEXT lets the auto-rollback semantics actually
   218	# work as designed.
   219	# r123 (2026-06-22) boot speed + cleanliness fix:
   220	#   - DROPPED console=ttyAMA2,115200 — /dev/ttyAMA2 does NOT enumerate on the
   221	#     MS-R1 when booting from disk (only the debug-harness exposes it). systemd
   222	#     auto-generates serial-getty@ttyAMA2 -> BindsTo dev-ttyAMA2.device, which
   223	#     then blocks boot for the full 90s device timeout. Removing it cuts ~90s.
   224	#   - DROPPED keep_bootcon — held the verbose early console through handoff,
   225	#     fighting the Plymouth splash. SPLASH="quiet splash" (below) is appended
   226	#     to stable+edge for a clean graphical boot; rescue stays verbose.
   227	#   - DROPPED loglevel — stable/edge get `quiet` (via SPLASH); rescue inherits
   228	#     this base WITHOUT splash so it boots at the kernel-default verbose level.
   229	LTS_CMDLINE_BASE="console=tty0 efi=noruntime acpi=force arm-smmu-v3.disable_bypass=0 audit_backlog_limit=8192 clk_ignore_unused panic=30 module_blacklist=typec_rts5453,rts5453"
   230	# r105 boot-visibility fix (2026-06-17): NEXT (7.0.x) does NOT get an early
   231	# framebuffer console like LTS does. With identical fb config, LTS's sysfb
   232	# registers an efi-framebuffer device → efifb binds → colour console + boot
   233	# penguins from ~1s. On 7.0.12, sysfb registers NO framebuffer device
   234	# (screen_info isn't populated for it — a 7.0.x regression vs 6.18), so the
   235	# panel is a dummy console until linlondp/panthor power on via SCMI at ~5.2s
   236	# — i.e. the whole early boot is invisible on HDMI.
   237	#   earlycon=efifb  — write straight to the firmware GOP framebuffer (the one
   238	#                     systemd-boot drew its menu on) from t=0, so early kernel
   239	#                     messages are visible on the panel before the real KMS
   240	#                     display comes up. keep_bootcon holds it through handoff.
   241	#   loglevel=7      — show info-level boot messages (NOT ignore_loglevel,
   242	#                     which firehoses debug spam onto the console at runtime).
   243	# Verified on .66: early messages now render on HDMI from boot. The brief
   244	# dark gap before the colour linlondp console is the SCMI display power-on
   245	# latency and is not removable from cmdline (needs efifb to bind early —
   246	# kernel-side screen_info fix, tracked separately).
   247	# r123: also dropped earlycon=efifb here. It was added (r105) to make early
   248	# NEXT boot text visible on HDMI before KMS, but that is exactly the verbose
   249	# "ugly" boot we now replace with the Plymouth splash. Early text is still
   250	# available via the rescue entry (verbose, no splash).
   251	NEXT_CMDLINE_BASE="console=tty0 acpi=force arm-smmu-v3.disable_bypass=0 audit_backlog_limit=8192 clk_ignore_unused panic=30 module_blacklist=typec_rts5453,rts5453"
   252	
   253	# Plymouth splash flags for a clean graphical boot. Appended to stable+edge
   254	# only (see LTS_OPTIONS/NEXT_OPTIONS below) — rescue deliberately omits these
   255	# so it stays text-verbose. 60-plymouth.sh sets the `nclawzero` default theme
   256	# and embeds it (+ the script module) in the initramfs; here we just pass the
   257	# kernel flags. An optional /etc/kernel/cmdline.d/10-splash.conf overrides.
   258	SPLASH="quiet splash"
   259	[ -f /etc/kernel/cmdline.d/10-splash.conf ] && SPLASH=$(cat /etc/kernel/cmdline.d/10-splash.conf)
