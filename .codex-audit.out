post-install/run-all.sh:10:#          system is unbootable. set -e applies here.
post-install/run-all.sh:15:# Phase 3: bootloader hook (70-bootloader.sh). Runs ALWAYS via the
post-install/run-all.sh:19:#          before 70-bootloader could clean+rewrite.
post-install/run-all.sh:22:# target so a successful boot can show "what was done" — useful
post-install/run-all.sh:36:# Best-effort: if tty3 isn't writable (post-reboot, or unusual context),
post-install/run-all.sh:44:# EXIT trap: run 70-bootloader.sh only after Phase 1 required hooks have
post-install/run-all.sh:48:finalize_bootloader() {
post-install/run-all.sh:51:    # Keep finalization best-effort so bootloader failure cannot skip
post-install/run-all.sh:58:        echo "[cix-installer] EXIT trap -> required phase failed; skipping bootloader"
post-install/run-all.sh:60:        echo "[cix-installer] 70-bootloader.sh skipped so a failed required hook cannot wipe the ESP"
post-install/run-all.sh:61:    elif [ -f /usr/local/lib/cix-installer/post-install/70-bootloader.sh ]; then
post-install/run-all.sh:64:        echo "[cix-installer] EXIT trap → finalizing bootloader"
post-install/run-all.sh:66:        bash /usr/local/lib/cix-installer/post-install/70-bootloader.sh \
post-install/run-all.sh:67:            2>&1 | tee "$LOGDIR/70-bootloader.log"
post-install/run-all.sh:70:            echo "[cix-installer] CRITICAL: 70-bootloader.sh failed rc=$BOOTLOADER_RC"
post-install/run-all.sh:71:            echo "[cix-installer] System will likely fail to boot — see $LOGDIR/70-bootloader.log"
post-install/run-all.sh:74:    # Run 99-diagnostics AFTER bootloader, so it captures the final
post-install/run-all.sh:75:    # /boot/efi/loader/ state (loader.conf, entries, vmlinuz-* layout).
post-install/run-all.sh:91:        echo "  bootloader + diagnostics still ran — system should boot"
post-install/run-all.sh:92:        echo "  to default kernel; logs available at /var/log/cix-install/"
post-install/run-all.sh:94:    # Codex A2 CRITICAL #1 fix: propagate bootloader failure to late_command
post-install/run-all.sh:95:    # so d-i marks install as failed if bootloader didn't install. Without
post-install/run-all.sh:96:    # this, late_command "succeeds" with no working bootloader and user
post-install/run-all.sh:97:    # boots to nothing.
post-install/run-all.sh:105:trap finalize_bootloader EXIT
post-install/run-all.sh:164:                # The EXIT trap will skip the bootloader because Phase 1 did
