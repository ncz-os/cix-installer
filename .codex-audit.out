   155	echo "[72] wrote marker $MARKER (PARTUUID=$RP_PARTUUID)"
   156	
   157	# --- finish: sync, unmount, reclaim space ---
   158	sync
   159	umount "$MNT" 2>/dev/null || true
   160	rm -f "$TARBALL" 2>/dev/null || true   # reclaim ~hundreds of MB on the main root
   161	echo "[72] rescue partition ready — 70-bootloader.sh will add the loader entry"
   162	exit 0

