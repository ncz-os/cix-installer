   119	KERNELS=""
   120	for sidecar in /usr/local/lib/cix-installer/KVER_LTS /usr/local/lib/cix-installer/KVER_NEXT; do
   121	    if [ -s "$sidecar" ]; then
   122	        kver=$(tr -d ' \t\r\n' < "$sidecar")
   123	        if [ -n "$kver" ] && [ -d "/lib/modules/$kver" ]; then
   124	            KERNELS="$KERNELS $kver"
