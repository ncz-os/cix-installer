post-install/70-bootloader.sh:2:# 70-bootloader.sh — rEFInd boot manager install + staged kernel menu.
post-install/70-bootloader.sh:3:# 26.6-r118: switched from systemd-boot to rEFInd (operator preference —
post-install/70-bootloader.sh:4:# "more resilient"; reverts to the 26.5 image-builder bootloader). rEFInd
post-install/70-bootloader.sh:8:# box boots even with an empty NVRAM BootOrder (confirmed on Sky1/MS-R1).
post-install/70-bootloader.sh:10:# Kernels + initrds are staged to the FAT ESP root (/boot/efi/vmlinuz-*,
post-install/70-bootloader.sh:11:# /boot/efi/initrd.img-*); rEFInd loads them directly from FAT and the
post-install/70-bootloader.sh:16:#   1. stable  — NCZ LTS kernel 6.18.x
post-install/70-bootloader.sh:17:#   2. edge    — NCZ NEXT 7.0.x kernel (DEFAULT when staged)
post-install/70-bootloader.sh:18:#   3. rescue  — pinned clean kernel, rescue.target, NPU/GPU/VPU/KMS blacklisted
post-install/70-bootloader.sh:22:#   /vmlinuz-$KVER_LTS          daily driver
post-install/70-bootloader.sh:23:#   /vmlinuz-$KVER_NEXT         edge [BETA] (default when staged)
post-install/70-bootloader.sh:24:#   /vmlinuz-$KVER_LTS-rescue   clean/rescue/dev — an independent, pinned
post-install/70-bootloader.sh:26:#                               daily-LTS kernel swap can never disturb the
post-install/70-bootloader.sh:29:# TRADEOFF vs systemd-boot (deliberate, r118): rEFInd has no boot-counting,
post-install/70-bootloader.sh:30:# so there is NO automatic edge->stable rollback. The 3-entry menu is for
post-install/70-bootloader.sh:32:# menu so the operator can pick stable/rescue if an edge boot misbehaves.
post-install/70-bootloader.sh:35:echo "[70] rEFInd bootloader (staged kernel menu)"
post-install/70-bootloader.sh:39:KVER_LTS=""
post-install/70-bootloader.sh:40:[ -f "$INSTALLER_META/KVER_LTS" ] && KVER_LTS=$(cat "$INSTALLER_META/KVER_LTS" 2>/dev/null || true)
post-install/70-bootloader.sh:41:KVER_NEXT=""
post-install/70-bootloader.sh:42:[ -f "$INSTALLER_META/KVER_NEXT" ] && KVER_NEXT=$(cat "$INSTALLER_META/KVER_NEXT" 2>/dev/null || true)
post-install/70-bootloader.sh:44:if [ -z "$KVER_LTS" ] && [ -z "$KVER_NEXT" ]; then
post-install/70-bootloader.sh:45:    echo "ERROR: no KVER_LTS or KVER_NEXT sidecar present"
post-install/70-bootloader.sh:52:echo "  KVER_LTS=$KVER_LTS"
post-install/70-bootloader.sh:53:echo "  KVER_NEXT=${KVER_NEXT:-(not present)}"
post-install/70-bootloader.sh:56:# Prevent systemd-boot deb postinst from double-staging kernels to the ESP
post-install/70-bootloader.sh:62:# needed (rEFInd isn't in Ubuntu ports' default pool). This also makes the
post-install/70-bootloader.sh:63:# bootloader install immune to the dpkg-wedge failure modes that previously
post-install/70-bootloader.sh:64:# made `apt install systemd-boot` flaky (a held dpkg frontend lock, or an
post-install/70-bootloader.sh:68:    echo "       (build did not stage build/refind-bin/refind_aa64.efi) — cannot install a bootloader."
post-install/70-bootloader.sh:72:# efibootmgr is best-effort only — we boot via the EFI/BOOT fallback path.
post-install/70-bootloader.sh:73:command -v efibootmgr >/dev/null 2>&1 || echo "  note: efibootmgr not present — relying on /EFI/BOOT/BOOTAA64.EFI fallback"
post-install/70-bootloader.sh:75:# Validate /boot/efi is actually mounted as the ESP — without this, a
post-install/70-bootloader.sh:76:# missing ESP mount (e.g. preseed partman edge case) would let
post-install/70-bootloader.sh:77:# `bootctl install` write loader files into a plain directory on the
post-install/70-bootloader.sh:79:# boot to nothing. Fail fast with clear diagnostics.
post-install/70-bootloader.sh:80:if ! findmnt -no FSTYPE /boot/efi >/dev/null 2>&1; then
post-install/70-bootloader.sh:81:    echo "ERROR: /boot/efi is not mounted — cannot install the bootloader."
post-install/70-bootloader.sh:82:    echo "  findmnt /boot/efi → not found"
post-install/70-bootloader.sh:85:    echo "  fstab entry for /boot/efi:"
post-install/70-bootloader.sh:86:    grep -E "/boot/efi" /etc/fstab 2>&1 || echo "  (no /boot/efi entry)"
post-install/70-bootloader.sh:89:ESP_FSTYPE=$(findmnt -no FSTYPE /boot/efi)
post-install/70-bootloader.sh:91:    echo "ERROR: /boot/efi is mounted as $ESP_FSTYPE, expected vfat (FAT32 ESP)."
post-install/70-bootloader.sh:94:echo "  /boot/efi is mounted (vfat) — proceeding with rEFInd install"
post-install/70-bootloader.sh:97:# kernel phase must not let this script wipe a previously bootable ESP.
