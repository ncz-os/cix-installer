   133	    done
   134	fi
   135	KERNELS=$(printf '%s\n' $KERNELS | awk 'NF && !seen[$0]++')
   136	if [ -z "$KERNELS" ]; then
   137	    echo "[60] ERROR: no target kernels found for Plymouth initramfs rebuild" >&2
   138	    exit 1
   139	fi
   140	
   141	for kver in $KERNELS; do
