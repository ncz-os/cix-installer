     1	#!/bin/bash
     2	# 60-plymouth.sh - Plymouth boot splash (NCZ black-hole theme). Optional.
     3	# r52: handle plymouth-quit.service failures gracefully (cosmetic, doesn't block boot).
     4	set -euo pipefail
     5	
     6	echo "[60] Plymouth boot splash"
     7	
     8	DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
     9	    plymouth plymouth-theme-spinner imagemagick || {
    10	    echo "[60] plymouth packages not available — skipping splash setup"
    11	    exit 0
    12	}
    13	
    14	# r130.5 (operator request): use the STOCK Ubuntu 'spinner' boot animation
    15	# (same as Xubuntu's) but rebranded with the NCZ logo — we cannot ship the
    16	# Xubuntu watermark. Earlier builds tried to apply a bespoke 'nclawzero' script
    17	# theme, but it never actually showed because the plymouth packages were not in
    18	# the offline pool (the install line failed → hook hit its `|| exit 0` guard →
    19	# Xubuntu's default logo remained). r130.4 bundles them; here we keep it simple:
    20	# overwrite the spinner theme's watermark with the NCZ wordmark and tint its
    21	# background to the NCZ charcoal so the mark blends, then pin spinner as default.
    22	SPIN_DIR=/usr/share/plymouth/themes/spinner
    23	SPIN_PLY="$SPIN_DIR/spinner.plymouth"
    24	ASSETS=/usr/local/lib/cix-installer/assets/branding
    25	LOGO_ASSETS="$ASSETS/logo"
    26	LOCKUP="$LOGO_ASSETS/nclawzero-lockup.jpg"
    27	
    28	if [ ! -f "$SPIN_PLY" ]; then
    29	    echo "[60] spinner theme not installed at $SPIN_DIR — cannot rebrand splash; skipping"
    30	    exit 0
    31	fi
    32	
    33	# Pick imagemagick binary (v7 'magick', v6 'convert').
    34	IM=""
    35	command -v magick  >/dev/null 2>&1 && IM=magick
    36	[ -z "$IM" ] && command -v convert >/dev/null 2>&1 && IM=convert
    37	
    38	# Replace the distro (Xubuntu) watermark with the NCZ wordmark. The lockup is a
    39	# 1024x1024 white "NCZ / nclawzero" mark on charcoal #0b0f14; crop the centre
    40	# band to a tight watermark. If imagemagick is somehow absent, fall back to the
    41	# full JPG re-saved as PNG so we still ship OUR logo, never Xubuntu's.
    42	if [ -n "$IM" ] && [ -f "$LOCKUP" ]; then
    43	    if "$IM" "$LOCKUP" -gravity center -crop 640x300+0+15 +repage "$SPIN_DIR/watermark.png" 2>/dev/null; then
    44	        echo "[60] installed NCZ watermark into spinner theme (cropped wordmark)"
    45	    else
    46	        "$IM" "$LOCKUP" "$SPIN_DIR/watermark.png" 2>/dev/null && \
    47	            echo "[60] installed NCZ watermark (full lockup; crop failed)"
    48	    fi
    49	elif [ -f "$LOCKUP" ]; then
    50	    # No imagemagick: at least make sure the Xubuntu watermark is gone. Copy the
    51	    # JPG bytes to watermark.png (plymouth reads by content, not extension).
    52	    cp -f "$LOCKUP" "$SPIN_DIR/watermark.png" && \
    53	        echo "[60] WARN: no imagemagick — copied raw lockup as watermark (uncropped)"
    54	else
    55	    echo "[60] WARN: NCZ lockup asset missing — leaving stock watermark" >&2
    56	fi
    57	
    58	# Tint the spinner background to NCZ charcoal (#0b0f14) so the cropped wordmark
    59	# (which carries that same charcoal) blends into a seamless splash. Idempotent.
    60	if grep -qE '^BackgroundStartColor=' "$SPIN_PLY"; then
    61	    sed -i -E 's/^BackgroundStartColor=.*/BackgroundStartColor=0x0b0f14/' "$SPIN_PLY"
    62	else
    63	    printf 'BackgroundStartColor=0x0b0f14\n' >> "$SPIN_PLY"
    64	fi
    65	if grep -qE '^BackgroundEndColor=' "$SPIN_PLY"; then
    66	    sed -i -E 's/^BackgroundEndColor=.*/BackgroundEndColor=0x0b0f14/' "$SPIN_PLY"
    67	else
    68	    printf 'BackgroundEndColor=0x0b0f14\n' >> "$SPIN_PLY"
    69	fi
    70	
    71	# r130.5 (operator: logo was at the bottom, wants it at the TOP). The spinner
    72	# (two-step) module places the watermark by WatermarkVerticalAlignment, a
    73	# fraction where 0=top and 1=bottom (stock Ubuntu uses ~.96 = bottom). Move it
    74	# near the top; .08 leaves a small margin so the 640x300 wordmark isn't jammed
    75	# against the edge on low-res GOP modes.
    76	if grep -qE '^WatermarkVerticalAlignment=' "$SPIN_PLY"; then
    77	    sed -i -E 's/^WatermarkVerticalAlignment=.*/WatermarkVerticalAlignment=.08/' "$SPIN_PLY"
    78	else
    79	    printf 'WatermarkVerticalAlignment=.08\n' >> "$SPIN_PLY"
    80	fi
    81	
    82	# Pin spinner as the default Plymouth theme. r123 lesson: register in MANUAL
    83	# (sticky) mode via update-alternatives --set so xubuntu-logo (from
    84	# xubuntu-default-settings, higher AUTO priority) cannot win and get embedded in
    85	# the initramfs instead. The target-kernel initramfs rebuild below then embeds
    86	# spinner (two-step module) + our watermark.
    87	export PATH="/usr/sbin:/sbin:/usr/bin:/bin:${PATH:-}"
    88	DEFAULT_PLY=/usr/share/plymouth/themes/default.plymouth
    89	update-alternatives --install "$DEFAULT_PLY" default.plymouth "$SPIN_PLY" 200
    90	update-alternatives --set default.plymouth "$SPIN_PLY"
    91	command -v plymouth-set-default-theme >/dev/null 2>&1 && \
    92	    plymouth-set-default-theme spinner 2>/dev/null || true
    93	echo "[60] default.plymouth -> $(readlink -f "$DEFAULT_PLY" 2>/dev/null) (manual)"
    94	
    95	# r130.5 (CRITICAL — operator: r130.5 hangs at the rebranded splash, box
    96	# unreachable): DO NOT mask plymouth-quit / plymouth-quit-wait. The old r51/r52
    97	# mask was only ever REACHED once the plymouth pkgs were bundled (r130.4+);
    98	# before that the hook exited at the apt-get `|| exit 0` guard, so the mask never
    99	# applied and boots worked. With the mask now active, the splash is never torn
   100	# down at the display-manager handoff and — together with the
   101	# NetworkManager-wait-online unmask in 33-network.sh — boot wedges behind the
   102	# splash (the operator sees the rendered NCZ logo, then nothing). The original
   103	# "plymouth-quit.service failed to start" was cosmetic and does NOT block boot.
   104	# Proactively UNMASK in case an earlier build left these units masked.
   105	systemctl unmask plymouth-quit.service plymouth-quit-wait.service 2>/dev/null || true
   106	
   107	echo "[60] plymouth splash configured (spinner + NCZ watermark); plymouth-quit left enabled"
   108	
   109	# r56: explicit plymouth theme set + initramfs rebuild
   110	# (the older plymouth-set-default-theme binary isn't always installed; do it by hand)
   111	mkdir -p /etc/plymouth
   112	cat > /etc/plymouth/plymouthd.conf <<EOF
   113	[Daemon]
   114	Theme=spinner
   115	ShowDelay=0
   116	DeviceTimeout=8
   117	EOF
