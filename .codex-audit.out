     1	#!/bin/bash
     2	# run-all.sh — orchestrate the numbered post-install hooks.
     3	#
     4	# Invoked from preseed late_command via in-target. Runs in chroot
     5	# context against the freshly-installed Debian Bookworm rootfs.
     6	#
     7	# 2026-05-03 — TWO-PHASE FAIL-TOLERANT PATTERN:
     8	#
     9	# Phase 1: required hooks (kernel install). MUST succeed or the
    10	#          system is unbootable. set -e applies here.
    11	# Phase 2: optional hooks (desktop, agents, plymouth, branding,
    12	#          ssh, claude-code, cix proprietary, quadlet shim). Each
    13	#          hook runs in isolation; failures get logged + recorded
    14	#          but DON'T abort.
    15	# Phase 3: bootloader hook (70-bootloader.sh). Runs ALWAYS via the
    16	#          EXIT trap, even if Phase 2 had failures. Without this,
    17	#          earlier r6/r7 installs left systems with stale loader
    18	#          entries from prior installs because run-all.sh aborted
    19	#          before 70-bootloader could clean+rewrite.
    20	#
    21	# Hook output is logged to /var/log/cix-install/<hook>.log on the
    22	# target so a successful boot can show "what was done" — useful
    23	# for demo + debugging.
    24	
    25	LOGDIR=/var/log/cix-install
    26	mkdir -p "$LOGDIR"
    27	cd /usr/local/lib/cix-installer/post-install
    28	
    29	# Track failures across phases for end-of-run summary.
    30	FAILED_HOOKS=""
    31	# Phase 1 must complete before the EXIT trap is allowed to touch the ESP.
    32	REQUIRED_PHASE_OK=0
    33	
    34	# r55+: surface progress on /dev/tty3 (the d-i log VT — Alt+F3 during install)
    35	# so users can watch hooks tick by instead of staring at d-i's stuck dialog.
    36	# Best-effort: if tty3 isn't writable (post-reboot, or unusual context),
    37	# falls back silently.
    38	TTY=/dev/tty3
    39	tty_msg() {
    40	    printf '[%s] %s\n' "$(date -u +%H:%M:%S)" "$*" >"$TTY" 2>/dev/null || true
    41	}
    42	tty_msg "==== run-all.sh: post-install hooks starting ===="
    43	
    44	# EXIT trap: run 70-bootloader.sh only after Phase 1 required hooks have
    45	# completed. It is invoked directly, not through the failure-tracking
    46	# machinery, since this trap fires after any earlier `exit` or `set -e`
    47	# propagation.
    48	finalize_bootloader() {
    49	    ORIGINAL_RC=$?
    50	    # The trap may run while Phase 1's `set -euo pipefail` is active.
    51	    # Keep finalization best-effort so bootloader failure cannot skip
    52	    # the diagnostics hook.
    53	    set +e
    54	    BOOTLOADER_RC=0
    55	    if [ "$ORIGINAL_RC" -ne 0 ] && [ "${REQUIRED_PHASE_OK:-0}" != "1" ]; then
    56	        echo ""
    57	        echo "============================================================"
    58	        echo "[cix-installer] EXIT trap -> required phase failed; skipping bootloader"
    59	        echo "============================================================"
    60	        echo "[cix-installer] 70-bootloader.sh skipped so a failed required hook cannot wipe the ESP"
    61	    elif [ -f /usr/local/lib/cix-installer/post-install/70-bootloader.sh ]; then
    62	        echo ""
    63	        echo "============================================================"
    64	        echo "[cix-installer] EXIT trap → finalizing bootloader"
    65	        echo "============================================================"
    66	        bash /usr/local/lib/cix-installer/post-install/70-bootloader.sh \
    67	            2>&1 | tee "$LOGDIR/70-bootloader.log"
    68	        BOOTLOADER_RC=${PIPESTATUS[0]}
    69	        if [ "$BOOTLOADER_RC" -ne 0 ]; then
    70	            echo "[cix-installer] CRITICAL: 70-bootloader.sh failed rc=$BOOTLOADER_RC"
    71	            echo "[cix-installer] System will likely fail to boot — see $LOGDIR/70-bootloader.log"
    72	        fi
    73	    fi
    74	    # Run 99-diagnostics AFTER bootloader, so it captures the final
    75	    # /boot/efi/loader/ state (loader.conf, entries, vmlinuz-* layout).
    76	    if [ -f /usr/local/lib/cix-installer/post-install/99-diagnostics.sh ]; then
    77	        echo ""
    78	        echo "============================================================"
    79	        echo "[cix-installer] EXIT trap → final diagnostics dump"
    80	        echo "============================================================"
    81	        bash /usr/local/lib/cix-installer/post-install/99-diagnostics.sh \
    82	            2>&1 | tee "$LOGDIR/99-diagnostics.log"
    83	        DIAGNOSTICS_RC=${PIPESTATUS[0]}
    84	        if [ "$DIAGNOSTICS_RC" -ne 0 ]; then
    85	            echo "[cix-installer] WARN: 99-diagnostics.sh hit errors rc=$DIAGNOSTICS_RC"
    86	        fi
    87	    fi
    88	    if [ -n "$FAILED_HOOKS" ]; then
    89	        echo ""
    90	        echo "[cix-installer] hooks that failed: $FAILED_HOOKS"
    91	        echo "  bootloader + diagnostics still ran — system should boot"
    92	        echo "  to default kernel; logs available at /var/log/cix-install/"
    93	    fi
    94	    # Codex A2 CRITICAL #1 fix: propagate bootloader failure to late_command
    95	    # so d-i marks install as failed if bootloader didn't install. Without
    96	    # this, late_command "succeeds" with no working bootloader and user
    97	    # boots to nothing.
    98	    if [ "$BOOTLOADER_RC" -ne 0 ]; then
    99	        exit "$BOOTLOADER_RC"
   100	    fi
   101	    if [ "$ORIGINAL_RC" -ne 0 ]; then
   102	        exit "$ORIGINAL_RC"
   103	    fi
   104	}
   105	trap finalize_bootloader EXIT
   106	
   107	# Phase 0: diagnostic affordance hooks (set +e) — run BEFORE Phase 1.
   108	# These create the magnetar diag account + any other "must exist before
   109	# the install can fail" affordances. Failures logged but never block the
   110	# install. Specifically: 09-diag-account.sh creates magnetar/diags
   111	# so a remote operator has a working SSH login the moment this chroot
   112	# touches /etc/passwd, regardless of whether 10-our-kernel.sh or any
   113	# subsequent hook crashes.
   114	#
   115	# Codex-found bug 2026-05-07: on r78-take2, magnetar was missing from
   116	# installed system because 09-diag-account.sh was in Phase 2 alphabetic
   117	# sort and the install never reached Phase 2 — 10-our-kernel.sh had
   118	# already aborted run-all.sh. Phase 0 fixes that.
   119	set +e
   120	tty_msg "Phase 0: diag affordance hooks (run BEFORE required kernel install)"
   121	for hook in $(ls 0[0-9]-*.sh 2>/dev/null | sort); do
   122	    LOG="$LOGDIR/${hook%.sh}.log"
   123	    HOOK_START=$(date +%s)
   124	    tty_msg "  → $hook (diag, non-blocking)"
   125	    echo ""
   126	    echo "============================================================"
   127	    echo "[cix-installer] [PHASE0] running $hook → $LOG"
   128	    echo "============================================================"
   129	    # Codex r78 audit MEDIUM (2026-05-07): pipefail is not enabled
   130	    # until Phase 1, so `if bash | tee ...` checks tee's exit code, not
   131	    # the hook's — hook syntax errors get reported as ✓ success on
   132	    # tty3. Mirror Phase 2's PIPESTATUS pattern instead.
   133	    bash ./"$hook" 2>&1 | tee "$LOG"
   134	    rc=${PIPESTATUS[0]}
   135	    HOOK_DUR=$(( $(date +%s) - HOOK_START ))
   136	    if [ "$rc" -eq 0 ]; then
   137	        tty_msg "  ✓ $hook done (${HOOK_DUR}s)"
   138	    else
   139	        tty_msg "  ⚠ $hook rc=$rc (${HOOK_DUR}s, continuing — Phase 0 is non-blocking)"
   140	        echo "[cix-installer] [PHASE0] WARN: $hook exited rc=$rc — install continues"
   141	    fi
   142	done
   143	
   144	# Phase 1: required hooks (set -e)
   145	set -euo pipefail
   146	tty_msg "Phase 1: required hooks (kernel + sky1-firmware + network)"
   147	for hook in $(ls [0-9][0-9]-*.sh | sort); do
   148	    case "$hook" in
   149	        10-our-kernel.sh|12-sky1-firmware.sh|33-network.sh)
   150	            LOG="$LOGDIR/${hook%.sh}.log"
   151	            HOOK_START=$(date +%s)
   152	            tty_msg "  → $hook (required)"
   153	            echo ""
   154	            echo "============================================================"
   155	            echo "[cix-installer] [REQUIRED] running $hook → $LOG"
   156	            echo "============================================================"
   157	            set +e
   158	            bash ./"$hook" 2>&1 | tee "$LOG"
   159	            rc=${PIPESTATUS[0]}
   160	            set -e
   161	            if [ "$rc" -ne 0 ]; then
   162	                tty_msg "  ✗ $hook FAILED rc=$rc — install aborts"
   163	                echo "[cix-installer] FATAL on $hook rc=$rc — install cannot continue"
   164	                # The EXIT trap will skip the bootloader because Phase 1 did
   165	                # not complete. Preserve the required hook rc.
   166	                exit "$rc"
   167	            fi
   168	            HOOK_DUR=$(( $(date +%s) - HOOK_START ))
   169	            tty_msg "  ✓ $hook done (${HOOK_DUR}s)"
   170	            ;;
   171	    esac
   172	done
   173	REQUIRED_PHASE_OK=1
   174	
   175	# Phase 2: optional hooks. Failures logged but don't abort.
   176	set +e
   177	tty_msg "Phase 2: optional hooks (desktop + agents + brand + ssh + ...)"
   178	OPT_HOOKS=$(ls [0-9][0-9]-*.sh 2>/dev/null | sort | grep -vE '^(0[0-9]|10-our-kernel|12-sky1-firmware|33-network|70-bootloader|99-diagnostics)\.sh$')
   179	TOTAL_OPT=$(echo "$OPT_HOOKS" | wc -l)
   180	IDX=0
   181	for hook in $OPT_HOOKS; do
   182	    IDX=$((IDX + 1))
   183	    LOG="$LOGDIR/${hook%.sh}.log"
   184	    HOOK_START=$(date +%s)
   185	    tty_msg "  → [$IDX/$TOTAL_OPT] $hook"
   186	    echo ""
   187	    echo "============================================================"
   188	    echo "[cix-installer] [OPTIONAL $IDX/$TOTAL_OPT] running $hook → $LOG"
   189	    echo "============================================================"
   190	    bash ./"$hook" 2>&1 | tee "$LOG"
   191	    rc=${PIPESTATUS[0]}
   192	    HOOK_DUR=$(( $(date +%s) - HOOK_START ))
   193	    if [ "$rc" -ne 0 ]; then
   194	        tty_msg "  ✗ [$IDX/$TOTAL_OPT] $hook FAILED rc=$rc (${HOOK_DUR}s) — continuing"
   195	        echo "[cix-installer] $hook FAILED rc=$rc — continuing (bootloader still writes)"
   196	        FAILED_HOOKS="$FAILED_HOOKS $hook"
   197	    else
   198	        tty_msg "  ✓ [$IDX/$TOTAL_OPT] $hook done (${HOOK_DUR}s)"
   199	    fi
   200	done
   201	
   202	echo ""
   203	echo "============================================================"
   204	if [ -z "$FAILED_HOOKS" ]; then
   205	    echo "[cix-installer] all optional hooks completed cleanly"
   206	    tty_msg "Phase 2 complete: all optional hooks OK"
   207	else
   208	    echo "[cix-installer] some optional hooks failed: $FAILED_HOOKS"
   209	    tty_msg "Phase 2 done with failures:$FAILED_HOOKS"
   210	fi
   211	echo "  → bootloader runs via EXIT trap next, then reboot"
   212	echo "============================================================"
   213	tty_msg "Phase 3: bootloader (EXIT trap)"
   214	# EXIT trap fires after this — bootloader runs there

