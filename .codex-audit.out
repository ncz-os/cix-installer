build/70-bootloader.sh:273:elif [ "$NEXT_AVAILABLE" = "1" ]; then
build/70-bootloader.sh:274:    RESCUE_KVER="$KVER_NEXT"
build/70-bootloader.sh:282:    cat > /boot/efi/loader/entries/cixmini-rescue.conf <<EOF
