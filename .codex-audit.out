     1	#!/bin/bash
     2	# 72-rescue-partition.sh — populate the r130 dedicated RESCUE PARTITION.
     3	#
     4	# The partman recipe in preseed-ubuntu.cfg creates a 4 GiB ext4 partition
     5	# (NCZRESCUE) with NO mountpoint on the main system. This hook fills it with
     6	# the pre-built rescue rootfs (assets/rescue/rescue-rootfs.tar.zst) and the
     7	# LTS kernel payload, then records a readiness marker.
     8	#
     9	# IMPORTANT — division of labour with 70-bootloader.sh:
    10	#   This hook runs in Phase 2 (numbered hooks). 70-bootloader.sh runs LATER,
    11	#   in run-all.sh's EXIT trap, and rewrites the ESP refind.conf + staged
    12	#   vmlinuz-* every run. So the rEFInd "RESCUE PARTITION" menuentry is written
    13	#   by 70-bootloader.sh (the sole ESP owner), gated on the RESCUE_READY marker
    14	#   this hook leaves behind. Here we only touch the rescue PARTITION (never the
    15	#   ESP), so nothing we do gets clobbered.
    16	#
    17	# r130.5 (operator): the dedicated rescue partition now ships the LTS 6.18
    18	# kernel (assets/kernel/stable), NOT the edge 7.0.x. A recovery environment
    19	# should be boring and reliable; the edge kernel's full accelerator/display
    20	# probing caused "sloppy device startup". 70-bootloader.sh boots this partition
    21	# with the same NPU/GPU/VPU/KMS module_blacklist as the rEFInd "rescue" entry.
    22	set -uo pipefail   # NOT -e: optional Phase-2 hook, must fail soft
    23	
    24	INSTALLER_META=/usr/local/lib/cix-installer
    25	ASSETS_KERNEL="$INSTALLER_META/assets/kernel"
    26	RESCUE_ASSETS="$INSTALLER_META/assets/rescue"
    27	TARBALL="$RESCUE_ASSETS/rescue-rootfs.tar.zst"
    28	MNT=/mnt/ncz-rescue
    29	MARKER="$INSTALLER_META/RESCUE_READY"
    30	
    31	echo "[72] rescue partition population"
    32	
    33	# --- preconditions (skip soft) ---
    34	KVER_LTS=""
    35	[ -f "$INSTALLER_META/KVER_LTS" ] && KVER_LTS=$(cat "$INSTALLER_META/KVER_LTS" 2>/dev/null || true)
    36	if [ -z "$KVER_LTS" ]; then
    37	    echo "[72] no LTS kernel staged — cannot build a clean rescue partition; skipping"
    38	    exit 0
    39	fi
    40	if [ ! -f "$TARBALL" ]; then
    41	    echo "[72] $TARBALL not present (run build/build-rescue-rootfs.sh at bake time) — skipping"
    42	    exit 0
    43	fi
    44	if [ ! -f "$ASSETS_KERNEL/stable/Image-cixmini.bin" ] || [ ! -f "$ASSETS_KERNEL/stable/modules-cixmini.tgz" ]; then
    45	    echo "[72] LTS kernel assets missing under $ASSETS_KERNEL/stable — skipping"
    46	    exit 0
    47	fi
    48	for t in blkid lsblk findmnt zstd tar depmod mkfs.ext4 e2label; do
    49	    command -v "$t" >/dev/null 2>&1 || { echo "[72] missing tool $t — skipping rescue partition"; exit 0; }
    50	done
    51	
    52	# --- locate the rescue partition ---
    53	ROOT_SRC=$(findmnt -no SOURCE / 2>/dev/null || true)
    54	ESP_SRC=$(findmnt -no SOURCE /boot/efi 2>/dev/null || true)
    55	echo "[72] root=$ROOT_SRC  esp=$ESP_SRC"
    56	
    57	RESCUE_SRC=$(blkid -L NCZRESCUE 2>/dev/null || true)
    58	if [ -z "$RESCUE_SRC" ]; then
    59	    # by GPT partition label
    60	    RESCUE_SRC=$(lsblk -rno NAME,PARTLABEL 2>/dev/null | awk '$2=="NCZRESCUE"{print "/dev/"$1}' | head -1)
    61	fi
    62	if [ -z "$RESCUE_SRC" ] && [ -n "$ROOT_SRC" ]; then
    63	    # by elimination: a partition on the root disk that is neither / nor ESP
    64	    DISK=$(lsblk -no PKNAME "$ROOT_SRC" 2>/dev/null | head -1)
    65	    if [ -n "$DISK" ]; then
    66	        for p in $(lsblk -rno NAME,TYPE "/dev/$DISK" 2>/dev/null | awk '$2=="part"{print "/dev/"$1}'); do
    67	            [ "$p" = "$ROOT_SRC" ] && continue
    68	            [ "$p" = "$ESP_SRC" ] && continue
    69	            RESCUE_SRC="$p"
    70	            break
    71	        done
    72	    fi
    73	fi
    74	if [ -z "$RESCUE_SRC" ] || [ ! -b "$RESCUE_SRC" ]; then
    75	    echo "[72] no rescue partition found (no NCZRESCUE, no spare partition) — skipping"
    76	    echo "      block devices:"; lsblk 2>&1 | sed 's/^/        /' | head -20
    77	    exit 0
    78	fi
    79	echo "[72] rescue partition = $RESCUE_SRC"
    80	
    81	# Guard: never clobber the live root or ESP.
    82	if [ "$RESCUE_SRC" = "$ROOT_SRC" ] || [ "$RESCUE_SRC" = "$ESP_SRC" ]; then
    83	    echo "[72] refusing to use $RESCUE_SRC (it is the live root or ESP) — skipping"
    84	    exit 0
    85	fi
    86	
    87	# --- ensure ext4 + label ---
    88	FST=$(blkid -s TYPE -o value "$RESCUE_SRC" 2>/dev/null || true)
    89	if [ "$FST" != "ext4" ]; then
    90	    echo "[72] $RESCUE_SRC is '$FST' — formatting ext4 (NCZRESCUE)"
    91	    mkfs.ext4 -F -L NCZRESCUE "$RESCUE_SRC" || { echo "[72] mkfs failed — skipping"; exit 0; }
    92	else
    93	    e2label "$RESCUE_SRC" NCZRESCUE 2>/dev/null || true
    94	fi
    95	
    96	# --- mount + extract rootfs ---
    97	mkdir -p "$MNT"
    98	umount "$MNT" 2>/dev/null || true
    99	if ! mount "$RESCUE_SRC" "$MNT"; then
   100	    echo "[72] mount $RESCUE_SRC failed — skipping"; exit 0
   101	fi
   102	
   103	echo "[72] extracting rescue rootfs -> $MNT"
   104	if ! zstd -dc "$TARBALL" | tar -xpf - -C "$MNT" --numeric-owner; then
   105	    echo "[72] rootfs extract failed — unmounting + skipping"
   106	    umount "$MNT" 2>/dev/null || true
   107	    exit 0
   108	fi
   109	
   110	# --- install EDGE kernel + modules into the rescue rootfs ---
   111	# Modules MUST go in via --keep-directory-symlink (never plain -C /): the
   112	# tarball carries a top-level lib/ entry, and on a usrmerge rootfs /lib is a
   113	# symlink to usr/lib. A naive extract would clobber that symlink and orphan
   114	# ld-linux — the exact failure mode this rescue env exists to repair.
   115	echo "[72] installing LTS kernel $KVER_LTS into rescue rootfs"
   116	install -D -m 0644 "$ASSETS_KERNEL/stable/Image-cixmini.bin" "$MNT/boot/vmlinuz-$KVER_LTS"
   117	tar xzf "$ASSETS_KERNEL/stable/modules-cixmini.tgz" -C "$MNT/usr" --strip-components=0 --keep-directory-symlink
   118	if [ ! -d "$MNT/usr/lib/modules/$KVER_LTS" ]; then
   119	    echo "[72] WARN: modules tarball did not produce $MNT/usr/lib/modules/$KVER_LTS"
   120	    ls "$MNT/usr/lib/modules/" 2>&1 | sed 's/^/        /'
   121	else
   122	    MODC=$(find "$MNT/usr/lib/modules/$KVER_LTS" -name '*.ko*' 2>/dev/null | wc -l)
   123	    echo "[72] $MODC modules staged; running depmod"
   124	    depmod -b "$MNT" "$KVER_LTS" 2>/dev/null || echo "[72] WARN: depmod returned non-zero"
   125	fi
   126	
   127	# initrd: reuse the main system's LTS initrd (generic; mounts root=PARTUUID).
   128	# 70-bootloader.sh stages the ESP copy; this in-rootfs copy is for completeness.
   129	if [ -s "/boot/initrd.img-$KVER_LTS" ]; then
