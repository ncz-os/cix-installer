build/build-iso-di.sh:595:# Step 4.5: GRAFT trixie's debootstrap + zstd shell-side udebs onto bookworm.
build/build-iso-di.sh:596:# Per 2026-05-04 install failure investigation: trixie bootstrap-base 1.226
build/build-iso-di.sh:597:# arm64 binaries (run-debootstrap, pkgdetails) are linked against glibc 2.38;
build/build-iso-di.sh:601:# Path A fix (no rebuild needed): bookworm bootstrap-base 1.213 ships a
build/build-iso-di.sh:602:# run-debootstrap binary linked against glibc 2.17/2.34 only AND it exec's
build/build-iso-di.sh:603:# /usr/sbin/debootstrap (verified via strings dump). So we keep bookworm's
build/build-iso-di.sh:604:# bootstrap-base + base-installer (which work on the bookworm runtime), and
build/build-iso-di.sh:605:# graft ONLY the all-arch shell pieces: trixie debootstrap-udeb 1.0.141 (the
build/build-iso-di.sh:606:# /usr/sbin/debootstrap shell with zstd support) plus trixie libzstd1-udeb +
build/build-iso-di.sh:607:# liblzma5-udeb (loaded as runtime deps when debootstrap calls zstd).
build/build-iso-di.sh:609:# Net flow at install time: bookworm bootstrap-base.run-debootstrap (libc 2.36
build/build-iso-di.sh:610:# compatible) -> exec /usr/sbin/debootstrap (trixie shell, zstd-aware) -> reads
build/build-iso-di.sh:614:# trixie's own debootstrap-udeb / libzstd1-udeb / liblzma5-udeb are already
build/build-iso-di.sh:622:echo "    grafting trixie shell-side udebs (debootstrap + libzstd + liblzma)"
build/build-iso-di.sh:627:    'pool/main/d/debootstrap/debootstrap-udeb_*_all.udeb' \
build/build-iso-di.sh:633:for need_pkg in debootstrap-udeb libzstd1-udeb liblzma5-udeb; do
build/build-iso-di.sh:639:    # Drop bookworm's cdebootstrap-static udebs (debootstrap replaces it)
build/build-iso-di.sh:640:    find "$STAGING"/pool/main/c/cdebootstrap -name '*.udeb' -delete 2>/dev/null || true
build/build-iso-di.sh:641:    rmdir --ignore-fail-on-non-empty "$STAGING"/pool/main/c/cdebootstrap 2>/dev/null || true
