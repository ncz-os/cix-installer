build/70-bootloader.sh:167:    echo "  staged /boot/efi/vmlinuz-$KVER_NEXT"
build/70-bootloader.sh:168:    NEXT_AVAILABLE=1
build/70-bootloader.sh:169:elif [ -n "$KVER_NEXT" ]; then
build/70-bootloader.sh:170:    echo "  WARN: /boot/vmlinuz-$KVER_NEXT missing — BETA entry will be SKIPPED"
build/70-bootloader.sh:173:if [ "$LTS_AVAILABLE" = "0" ] && [ "$NEXT_AVAILABLE" = "0" ]; then
build/70-bootloader.sh:174:    echo "ERROR: NEITHER kernel installed — system is unbootable."
build/70-bootloader.sh:180:# Entry — cixmini-lts.conf (FALLBACK — CIX BSP 6.18.26-cix-sky1-lts, stable)
build/70-bootloader.sh:182:if [ "$LTS_AVAILABLE" = "1" ]; then
build/70-bootloader.sh:183:    LTS_OPTIONS="$ROOT_OPTS $MARTJOHNSON_CMDLINE"
build/70-bootloader.sh:184:    [ -n "$SPLASH" ] && LTS_OPTIONS="$LTS_OPTIONS $SPLASH"
build/70-bootloader.sh:186:    # sort-key forces menu-order (systemd-boot 252+). LTS is the stable
build/70-bootloader.sh:187:    # fallback so it sorts below the default 7.0.12 headline entry.
build/70-bootloader.sh:188:    cat > /boot/efi/loader/entries/cixmini-lts.conf <<EOF
build/70-bootloader.sh:189:title   nclawzero (cixmini) — kernel $KVER_LTS [LTS — CIX BSP, stable fallback] — $BUILD_VERSION
build/70-bootloader.sh:191:version $KVER_LTS
