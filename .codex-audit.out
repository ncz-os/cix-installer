post-install/70-bootloader.sh:123:        echo "ERROR: /boot/vmlinuz-$KVER_LTS exists but /boot/initrd.img-$KVER_LTS is missing or empty."
post-install/70-bootloader.sh:124:        echo "       Refusing to wipe the ESP without a complete LTS kernel payload."
post-install/70-bootloader.sh:126:    elif [ -e "/boot/vmlinuz-$KVER_LTS" ]; then
post-install/70-bootloader.sh:127:        echo "ERROR: incomplete LTS kernel payload for $KVER_LTS."
post-install/70-bootloader.sh:128:        echo "       Need non-empty /boot/vmlinuz-$KVER_LTS and /boot/initrd.img-$KVER_LTS before ESP wipe."
post-install/70-bootloader.sh:131:        echo "  WARN: LTS kernel payload for $KVER_LTS missing — LTS entry will be skipped"
post-install/70-bootloader.sh:134:if [ -n "$KVER_NEXT" ]; then
post-install/70-bootloader.sh:135:    if [ -s "/boot/vmlinuz-$KVER_NEXT" ] && [ -s "/boot/initrd.img-$KVER_NEXT" ]; then
post-install/70-bootloader.sh:136:        verify_payload_readable "NEXT kernel" "/boot/vmlinuz-$KVER_NEXT"
post-install/70-bootloader.sh:137:        verify_payload_readable "NEXT initrd" "/boot/initrd.img-$KVER_NEXT"
post-install/70-bootloader.sh:138:        NEXT_PREFLIGHT_READY=1
post-install/70-bootloader.sh:139:        echo "  preflight OK: NEXT kernel/initrd present and readable for $KVER_NEXT"
post-install/70-bootloader.sh:140:    elif [ -s "/boot/vmlinuz-$KVER_NEXT" ] && [ ! -s "/boot/initrd.img-$KVER_NEXT" ]; then
post-install/70-bootloader.sh:141:        echo "ERROR: /boot/vmlinuz-$KVER_NEXT exists but /boot/initrd.img-$KVER_NEXT is missing or empty."
post-install/70-bootloader.sh:142:        echo "       Refusing to wipe the ESP without a complete NEXT kernel payload."
post-install/70-bootloader.sh:144:    elif [ -e "/boot/vmlinuz-$KVER_NEXT" ]; then
post-install/70-bootloader.sh:145:        echo "ERROR: incomplete NEXT kernel payload for $KVER_NEXT."
post-install/70-bootloader.sh:146:        echo "       Need non-empty /boot/vmlinuz-$KVER_NEXT and /boot/initrd.img-$KVER_NEXT before ESP wipe."
post-install/70-bootloader.sh:149:        echo "  WARN: NEXT kernel payload for $KVER_NEXT missing — NEXT entry will be skipped"
post-install/70-bootloader.sh:152:if [ "$LTS_PREFLIGHT_READY" = "0" ] && [ "$NEXT_PREFLIGHT_READY" = "0" ]; then
