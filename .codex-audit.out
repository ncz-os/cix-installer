build/70-bootloader.sh:2:# 70-bootloader.sh — systemd-boot install + DUAL-kernel loader entries.
build/70-bootloader.sh:4:# Loader entries (only TWO kernel binaries on the ESP — LTS + NEXT; the
build/70-bootloader.sh:5:# safe/rescue entries reuse the LTS binary):
build/70-bootloader.sh:6:#   1. cixmini-next.conf      (DEFAULT — homegrown Sky1 7.0.12, headline kernel)
build/70-bootloader.sh:7:#   2. cixmini-lts.conf       (fallback — CIX BSP Sky1 6.18.26-cix-sky1-lts, stable)
build/70-bootloader.sh:8:#   3. cixmini-lts-safe.conf  (safe graphics — LTS w/ Sky1 accelerators blacklisted)
build/70-bootloader.sh:9:#   4. cixmini-rescue.conf    (rescue.target on LTS kernel)
build/70-bootloader.sh:11:# CRITICAL: systemd-boot's loader entry parser does NOT support
build/70-bootloader.sh:13:# version tried multi-line `options \` and bootctl silently dropped
build/70-bootloader.sh:14:# half the cmdline.
build/70-bootloader.sh:17:echo "[70] systemd-boot bootloader (DUAL kernel — 7.0.12 default + 6.18 LTS fallback)"
build/70-bootloader.sh:20:[ -f "$INSTALLER_META/KVER_LTS" ] || { echo "ERROR: KVER_LTS sidecar missing"; exit 1; }
build/70-bootloader.sh:21:KVER_LTS=$(cat "$INSTALLER_META/KVER_LTS")
build/70-bootloader.sh:22:KVER_NEXT=""
build/70-bootloader.sh:23:[ -f "$INSTALLER_META/KVER_NEXT" ] && KVER_NEXT=$(cat "$INSTALLER_META/KVER_NEXT" 2>/dev/null || true)
build/70-bootloader.sh:28:echo "  KVER_LTS=$KVER_LTS"
build/70-bootloader.sh:29:echo "  KVER_NEXT=${KVER_NEXT:-(not present)}"
build/70-bootloader.sh:33:# Install systemd-boot + efibootmgr
build/70-bootloader.sh:36:    systemd-boot efibootmgr || true
build/70-bootloader.sh:38:command -v bootctl >/dev/null || { echo "ERROR: bootctl not installed"; exit 1; }
build/70-bootloader.sh:40:# Validate /boot/efi is actually mounted as the ESP — without this, a
build/70-bootloader.sh:41:# missing ESP mount (e.g. preseed partman edge case) would let
build/70-bootloader.sh:42:# `bootctl install` write loader files into a plain directory on the
build/70-bootloader.sh:44:# boot to nothing. Fail fast with clear diagnostics.
build/70-bootloader.sh:45:if ! findmnt -no FSTYPE /boot/efi >/dev/null 2>&1; then
build/70-bootloader.sh:46:    echo "ERROR: /boot/efi is not mounted — cannot install systemd-boot."
build/70-bootloader.sh:47:    echo "  findmnt /boot/efi → not found"
build/70-bootloader.sh:50:    echo "  fstab entry for /boot/efi:"
build/70-bootloader.sh:51:    grep -E "/boot/efi" /etc/fstab 2>&1 || echo "  (no /boot/efi entry)"
build/70-bootloader.sh:54:ESP_FSTYPE=$(findmnt -no FSTYPE /boot/efi)
build/70-bootloader.sh:56:    echo "ERROR: /boot/efi is mounted as $ESP_FSTYPE, expected vfat (FAT32 ESP)."
build/70-bootloader.sh:59:echo "  /boot/efi is mounted (vfat) — proceeding with systemd-boot install"
build/70-bootloader.sh:62:# chroot / QEMU without RW efivarfs), fall back to default if that
build/70-bootloader.sh:63:# rejects. If BOTH fail, that's a hard error; without bootctl install,
build/70-bootloader.sh:64:# /boot/efi/EFI/systemd/systemd-bootaa64.efi won't be on the ESP and
build/70-bootloader.sh:66:if ! bootctl install --esp-path=/boot/efi --no-variables 2>&1; then
build/70-bootloader.sh:68:    if ! bootctl install --esp-path=/boot/efi 2>&1; then
build/70-bootloader.sh:69:        echo "ERROR: both bootctl install attempts failed."
build/70-bootloader.sh:70:        echo "  Check /boot/efi mount + writability + /sys/firmware/efi/efivars."
build/70-bootloader.sh:74:# Verify the systemd-boot binary actually landed on the ESP
build/70-bootloader.sh:75:if [ ! -f /boot/efi/EFI/systemd/systemd-bootaa64.efi ]; then
build/70-bootloader.sh:76:    echo "ERROR: bootctl install reported success but"
build/70-bootloader.sh:77:    echo "       /boot/efi/EFI/systemd/systemd-bootaa64.efi is missing."
build/70-bootloader.sh:78:    ls -la /boot/efi/EFI/ 2>&1 | head -10 || true
build/70-bootloader.sh:81:echo "  systemd-bootaa64.efi present on ESP"
build/70-bootloader.sh:87:# vmlinuz copies on the ESP. systemd-boot reads ALL *.conf files in
build/70-bootloader.sh:88:# /boot/efi/loader/entries/ — leftover entries from r1/r2/r3 installs
build/70-bootloader.sh:89:# show up alongside the new ones, defaulting to whichever has the
build/70-bootloader.sh:91:# entries on cixmini.66 (r6 era + earlier) and confused systemd-boot's
build/70-bootloader.sh:92:# default selection.
build/70-bootloader.sh:97:rm -f /boot/efi/loader/entries/*.conf
build/70-bootloader.sh:98:rm -f /boot/efi/vmlinuz-*
build/70-bootloader.sh:99:# Some installs put kernels in /boot/efi/EFI/Linux/ via systemd-boot's
build/70-bootloader.sh:101:rm -f /boot/efi/EFI/Linux/*.efi 2>/dev/null
build/70-bootloader.sh:107:mkdir -p /boot/efi/loader/entries
build/70-bootloader.sh:108:cat > /boot/efi/loader/loader.conf <<'EOF'
build/70-bootloader.sh:109:default cixmini-next
build/70-bootloader.sh:122:# Cmdline (MartJohnson 2026-04-30 working set for MS-R1, both LTS+NEXT)
build/70-bootloader.sh:124:#   loglevel=4                          — visible kernel msgs through boot
build/70-bootloader.sh:129:#   audit_backlog_limit=8192            — early-boot audit subsystem doesn't drop msgs
build/70-bootloader.sh:131:#   keep_bootcon                        — early console persists through handoff
build/70-bootloader.sh:132:#   panic=30                            — 30s grace before reboot on panic
build/70-bootloader.sh:135:# so cmdline module_blacklist=armchina_npu is unnecessary. We don't
build/70-bootloader.sh:136:# add module blacklists here — the configs already disable everything
build/70-bootloader.sh:137:# that would cause boot trouble on MS-R1.
build/70-bootloader.sh:139:MARTJOHNSON_CMDLINE="loglevel=4 console=tty0 console=ttyAMA2,115200 efi=noruntime acpi=force arm-smmu-v3.disable_bypass=0 audit_backlog_limit=8192 clk_ignore_unused keep_bootcon panic=30 module_blacklist=typec_rts5453,rts5453 video=DP-4:1920x1080@60e"
build/70-bootloader.sh:143:[ -f /etc/kernel/cmdline.d/10-splash.conf ] && SPLASH=$(cat /etc/kernel/cmdline.d/10-splash.conf)
build/70-bootloader.sh:148:# Stage kernels onto ESP — systemd-boot reads /boot/efi by default.
build/70-bootloader.sh:152:# loader entry. Don't hard-fail the whole bootloader hook.
build/70-bootloader.sh:154:LTS_AVAILABLE=0
build/70-bootloader.sh:155:NEXT_AVAILABLE=0
build/70-bootloader.sh:157:if [ -f "/boot/vmlinuz-$KVER_LTS" ]; then
build/70-bootloader.sh:158:    install -m 0644 "/boot/vmlinuz-$KVER_LTS" "/boot/efi/vmlinuz-$KVER_LTS"
build/70-bootloader.sh:159:    echo "  staged /boot/efi/vmlinuz-$KVER_LTS"
build/70-bootloader.sh:160:    LTS_AVAILABLE=1
build/70-bootloader.sh:162:    echo "  WARN: /boot/vmlinuz-$KVER_LTS missing — LTS entry will be SKIPPED"
build/70-bootloader.sh:165:if [ -n "$KVER_NEXT" ] && [ -f "/boot/vmlinuz-$KVER_NEXT" ]; then
