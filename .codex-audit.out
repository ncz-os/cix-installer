build/70-bootloader.sh:293:# LTS only if the headline kernel isn't present. Re-write loader.conf to match
build/70-bootloader.sh:295:if [ "$NEXT_AVAILABLE" = "1" ]; then
build/70-bootloader.sh:300:cat > /boot/efi/loader/loader.conf <<EOF
