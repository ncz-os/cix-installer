     1	#!/bin/bash
     2	# 33-network.sh — wire NetworkManager as the active netplan renderer.
     3	#
     4	# 2026-05-08 take23 (per .66 take22 install): resolute defaults to
     5	# systemd-networkd OR nothing if neither netplan config is present.
     6	# The XFCE dep chain on resolute does not pull network-manager the way
     7	# questing's did, so the previous build relied on an implicit pull
     8	# that no longer happens.
     9	#
    10	# This hook (a) confirms network-manager is installed (preseed
    11	# pkgsel/include adds it; verify here in case operator/dpkg state
    12	# diverged), (b) writes a netplan YAML that uses NetworkManager
    13	# renderer + matches every en* / wl* interface for DHCP, (c)
    14	# disables systemd-networkd if it was somehow active so it doesn't
    15	# fight NM, (d) enables NM at boot.
    16	#
    17	# Idempotent: re-runnable; sed-guards prevent duplicate writes.
    18	
    19	set -euo pipefail
    20	
    21	echo "[33-network] verifying NetworkManager + writing netplan"
    22	
    23	# (a) Hard-fail if NM is not installed. preseed pkgsel/include puts it
    24	# there; if it is missing, the netinstall apt fetch failed silently and
    25	# the operator-visible symptom (no network) is exactly what we are
    26	# trying to prevent.
    27	if ! command -v nmcli >/dev/null 2>&1 || ! dpkg-query -W -f='${Status}\n' network-manager 2>/dev/null | grep -q "install ok installed"; then
    28	    echo "[33-network] ERROR: network-manager not installed; aborting" >&2
    29	    echo "[33-network] preseed/preseed-ubuntu.cfg pkgsel/include must list network-manager" >&2
    30	    exit 1
    31	fi
    32	
    33	# (b) netplan with NetworkManager as renderer + match every wired/wireless
    34	# interface for DHCP. Wildcards survive interface-rename churn between
    35	# kernel boots (enp1s0 vs enp2s0 etc.).
    36	NETPLAN_DIR=/etc/netplan
    37	install -d -m 0755 "$NETPLAN_DIR"
    38	
    39	NETPLAN_FILE="$NETPLAN_DIR/01-ncz-networkmanager.yaml"
    40	cat > "$NETPLAN_FILE" <<'YAML'
    41	# Written by ncz-installer post-install/33-network.sh
    42	# All wired + wireless interfaces are managed by NetworkManager.
    43	# DHCP is the default; operator can override via nm-applet or nmcli.
    44	network:
    45	  version: 2
    46	  renderer: NetworkManager
    47	  ethernets:
    48	    # r130.5 (Codex review): explicit wired DHCP profiles. Two reasons:
    49	    #   1. guarantees NM has an auto-connect profile for the wired NIC on
    50	    #      first boot (don't rely solely on NM's implicit auto-default).
    51	    #   2. optional:true keeps NetworkManager-wait-online.service (which
    52	    #      33-network unmasks+enables below) from BLOCKING network-online
    53	    #      at boot when the wired link has no carrier/lease — that stall,
    54	    #      behind the boot splash, looked like a hang on the .66 install.
    55	    # Wildcard match survives enp1s0<->enp49s0 rename churn across boots.
    56	    ncz-wired-en:
    57	      match:
    58	        name: "en*"
    59	      dhcp4: true
    60	      dhcp6: true
    61	      optional: true
    62	    ncz-wired-eth:
    63	      match:
    64	        name: "eth*"
    65	      dhcp4: true
    66	      dhcp6: true
    67	      optional: true
    68	YAML
    69	chmod 0600 "$NETPLAN_FILE"
    70	
    71	# Remove cloud-init's generated 50-cloud-init.yaml and any other
    72	# competing netplan configs that would re-render to systemd-networkd.
    73	for stale in 50-cloud-init.yaml 99_cloud-init.yaml 00-installer-config.yaml; do
    74	    if [ -f "$NETPLAN_DIR/$stale" ]; then
    75	        echo "[33-network] removing stale $stale (would compete with NM renderer)"
    76	        rm -f "$NETPLAN_DIR/$stale"
    77	    fi
    78	done
    79	
    80	# (b2) r130.5 (CRITICAL — .27/.66 install: wired NIC never got DHCP):
    81	# d-i's netcfg writes /etc/network/interfaces with the INSTALL-TIME wired NIC
    82	# as `allow-hotplug <if>` + `iface <if> inet dhcp`, and the stock
    83	# /etc/NetworkManager/NetworkManager.conf ships `[ifupdown] managed=false`.
    84	# Together that makes NM HAND OFF any interface named in
    85	# /etc/network/interfaces to ifupdown (nmcli shows STATE=unmanaged, reason 76
    86	# "unmanaged by user decision via settings plugin"). On the XFCE/NM desktop
    87	# ifupdown is not actively raising the link, so the wired port never gets DHCP
    88	# while wifi (absent from the file) works — exactly the "DHCP broke, wired
    89	# unmanaged" symptom. Fix BOTH halves so NM owns every real NIC:
    90	#   1. flip [ifupdown] managed=false -> true (NM manages even listed devices)
    91	#   2. reset /etc/network/interfaces to loopback-only (drop the d-i dhcp stanza)
    92	NM_CONF=/etc/NetworkManager/NetworkManager.conf
    93	install -d -m 0755 "$(dirname "$NM_CONF")"
    94	if [ -f "$NM_CONF" ] && grep -qE '^[[:space:]]*managed=false' "$NM_CONF"; then
    95	    sed -i -E 's/^[[:space:]]*managed=false/managed=true/' "$NM_CONF"
    96	    echo "[33-network] flipped [ifupdown] managed=false -> true in $NM_CONF"
    97	elif [ -f "$NM_CONF" ] && grep -qE '^\[ifupdown\]' "$NM_CONF" && ! grep -qE '^[[:space:]]*managed=' "$NM_CONF"; then
    98	    sed -i '/^\[ifupdown\]/a managed=true' "$NM_CONF"
    99	    echo "[33-network] added managed=true under existing [ifupdown] in $NM_CONF"
   100	elif [ ! -f "$NM_CONF" ] || ! grep -qE '^\[ifupdown\]' "$NM_CONF"; then
   101	    printf '\n[ifupdown]\nmanaged=true\n' >> "$NM_CONF"
   102	    echo "[33-network] appended [ifupdown] managed=true to $NM_CONF"
   103	fi
   104	
   105	ENI=/etc/network/interfaces
   106	if [ -f "$ENI" ] && grep -qE '^[[:space:]]*(allow-hotplug|auto)[[:space:]]+(en|eth|wl)' "$ENI"; then
   107	    echo "[33-network] resetting $ENI to loopback-only (d-i had pinned the install NIC to inet dhcp)"
   108	fi
   109	cat > "$ENI" <<'ENICONF'
   110	# Reset by ncz-installer post-install/33-network.sh.
   111	# All real NICs are owned by NetworkManager (see
   112	# /etc/netplan/01-ncz-networkmanager.yaml). d-i's netcfg had written the
   113	# install-time wired NIC here as `iface <if> inet dhcp`, which NM hands off to
   114	# ifupdown ([ifupdown] managed=false) -> the wired port never got DHCP. Keeping
   115	# this loopback-only leaves NM in sole control of all wired + wireless links.
   116	source /etc/network/interfaces.d/*
   117	
   118	auto lo
   119	iface lo inet loopback
   120	ENICONF
   121	
   122	# (c) Disable systemd-networkd so it does not race NM for the link.
   123	# `mask` is stronger than `disable` because it survives package
   124	# upgrades that re-enable units.
   125	systemctl disable --now systemd-networkd.socket 2>/dev/null || true
   126	systemctl disable --now systemd-networkd 2>/dev/null || true
   127	systemctl mask systemd-networkd 2>/dev/null || true
   128	
   129	# (d) NetworkManager enabled at boot.
   130	systemctl enable NetworkManager 2>&1 | tail -3 || true
   131	
   132	# (d2) Restore real network-online semantics. The base rootfs ships
   133	# NetworkManager-wait-online.service masked (a boot-speed default),
   134	# which silently neutralises every "After=network-online.target"
   135	# ordering: timer/oneshot units (e.g. nclawzero-load-agent-images)
   136	# then fire before DHCP/link is up and fail at boot. Unmask + enable
   137	# so network-online.target actually waits for NM. This is bounded by
   138	# NM_ONLINE_TIMEOUT (~30s) and never blocks login/ssh, which are gated
   139	# on network.target (link present), not network-online.target.
   140	systemctl unmask NetworkManager-wait-online.service 2>/dev/null || true
   141	systemctl enable NetworkManager-wait-online.service 2>&1 | tail -2 || true
   142	# Don't try to start NM in the chroot — the host has no live network
   143	# stack to manage. First boot will pick it up via the enable.
   144	
   145	# Apply netplan to regenerate /run/NetworkManager/conf.d/*. This does
   146	# NOT bring up interfaces in the chroot (no live stack); it just
   147	# updates the rendered config that NM will read on first boot.
   148	netplan generate 2>&1 | tail -3 || \
   149	    echo "[33-network] WARN: netplan generate failed (likely chroot — first-boot will retry)"
   150	
   151	echo "[33-network] netplan written; NM enabled; systemd-networkd masked"

