build/70-bootloader.sh:227:version $KVER_LTS
build/70-bootloader.sh:228:linux   /vmlinuz-$KVER_LTS
build/70-bootloader.sh:231:    echo "  wrote cixmini-lts-safe.conf (sort-key 3-lts-safe, blacklist=$SAFE_BLACKLIST)"
build/70-bootloader.sh:233:    echo "  skipping cixmini-lts-safe.conf (LTS kernel not installed)"
build/70-bootloader.sh:237:# Entry — cixmini-next.conf (DEFAULT — homegrown headline kernel 7.0.12)
build/70-bootloader.sh:239:# 7.0.12 is the homegrown headline kernel with the full Sky1 stack in-tree
build/70-bootloader.sh:240:# (display/audio/NPU/etc.) and is the default boot target. The earlier
build/70-bootloader.sh:241:# [BETA] warning applied to 7.0.1 (Sky1-Linux #12: SCMI transition errors /
build/70-bootloader.sh:242:# boot freezes before the BIOS SCMI updates); 7.0.12 is the validated
build/70-bootloader.sh:243:# default. The CIX BSP 6.18 LTS remains as the conservative fallback entry.
build/70-bootloader.sh:245:if [ "$NEXT_AVAILABLE" = "1" ]; then
build/70-bootloader.sh:246:    NEXT_OPTIONS="$ROOT_OPTS $MARTJOHNSON_CMDLINE"
build/70-bootloader.sh:247:    [ -n "$SPLASH" ] && NEXT_OPTIONS="$NEXT_OPTIONS $SPLASH"
build/70-bootloader.sh:249:    # sort-key 1-next keeps the default headline kernel at the top of the menu.
build/70-bootloader.sh:250:    cat > /boot/efi/loader/entries/cixmini-next.conf <<EOF
build/70-bootloader.sh:251:title   nclawzero (cixmini) — kernel $KVER_NEXT [headline, default] — $BUILD_VERSION
build/70-bootloader.sh:253:version $KVER_NEXT
build/70-bootloader.sh:254:linux   /vmlinuz-$KVER_NEXT
build/70-bootloader.sh:255:options $NEXT_OPTIONS
build/70-bootloader.sh:257:    echo "  wrote cixmini-next.conf (default, sort-key 1-next)"
build/70-bootloader.sh:263:# Entry 3 — cixmini-rescue.conf (rescue shell on LTS kernel)
build/70-bootloader.sh:265:# rescue.target boots multi-user services down (no graphical, no
build/70-bootloader.sh:266:# auto-mount of network FS) but leaves the system bootable + login-able
build/70-bootloader.sh:267:# for recovery. Useful when default cixmini-lts.conf wedges from a bad
build/70-bootloader.sh:270:# Rescue uses LTS by preference, falls back to NEXT if LTS missing.
build/70-bootloader.sh:271:if [ "$LTS_AVAILABLE" = "1" ]; then
