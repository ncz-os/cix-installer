     1	#!/bin/bash
     2	# 80-npu.sh — install NCZ NPU stack for Cix Sky1 / Zhouyi v3
     3	#
     4	# Source: FyrbyAdditive/ms-r1-npu-hack (BSD-2-Clause-Patent)
     5	#   + cixtech/cix_opensource__release__npu_driver branch cix_mainline_dev
     6	#
     7	# Four MS-R1 fixes applied in the kernel module:
     8	#   1. ACPI SSDT override: _HID="CIXH4010" on NPU cores (missing in shipped BIOS)
     9	#   2. v0-compat ioctl handlers: translates cix-noe-umd 2.0.x struct layouts
    10	#   3. SMMU 32-bit constraint: forces bus_dma_limit=0xc0000000, dma_mask=32
    11	#   4. asid_base[4]->asid_base[32] widening for QUERY_CAP UMD ABI compat
    12	#
    13	# Result: mobilenet_v2.cix runs at ~640 inf/s (1.5ms avg) via cix-noe-umd 2.0.2
    14	#
    15	# RUNS INSIDE CHROOT (via run-all.sh). All paths are relative to the
    16	# installed system root (no /target/ prefix).
    17	#
    18	# Ordering: this hook runs before 70-bootloader.sh (which fires on EXIT trap).
    19	# Sequence:
    20	#   1. install .ko into /usr/lib/modules/$KVER/extra/
    21	#   2. depmod -a $KVER
    22	#   3. ensure /boot/initrd.img-$KVER exists (normally generated by 10-our-kernel.sh)
    23	#   4. prepend npu-acpi-override.cpio to /boot/initrd.img-$KVER
    24	#   5. configure modules-load.d
    25	# Then 70-bootloader.sh stages /boot/initrd.img-$KVER → /boot/efi/initrd.img-$KVER
    26	# and adds `initrd /initrd.img-$KVER` to the systemd-boot loader entries.
    27	
    28	set +e
    29	
    30	INSTALLER_META=/usr/local/lib/cix-installer
    31	ASSETS=/usr/local/lib/cix-installer/assets/npu
    32	if [ ! -d "$ASSETS" ] && [ -d /cdrom/cixmini/assets/npu ]; then
    33	    ASSETS=/cdrom/cixmini/assets/npu
    34	fi
    35	SSDT_CPIO="$ASSETS/npu-acpi-override.cpio"
    36	
    37	KERNEL_LABELS=()
    38	KERNEL_VERS=()
    39	if [ -f "$INSTALLER_META/KVER_LTS" ]; then
    40	    KVER_LTS=$(cat "$INSTALLER_META/KVER_LTS" 2>/dev/null | tr -d ' \t\r\n')
    41	    if [ -n "$KVER_LTS" ]; then
    42	        KERNEL_LABELS+=("lts")
    43	        KERNEL_VERS+=("$KVER_LTS")
    44	    fi
    45	fi
    46	if [ -f "$INSTALLER_META/KVER_NEXT" ]; then
    47	    KVER_NEXT=$(cat "$INSTALLER_META/KVER_NEXT" 2>/dev/null | tr -d ' \t\r\n')
    48	    if [ -n "$KVER_NEXT" ]; then
    49	        KERNEL_LABELS+=("next")
    50	        KERNEL_VERS+=("$KVER_NEXT")
    51	    fi
    52	fi
    53	
    54	if [ "${#KERNEL_VERS[@]}" -eq 0 ]; then
    55	    echo "[80] WARN: no KVER_LTS or KVER_NEXT sidecar found; skipping kernel-specific NPU setup"
    56	fi
    57	if [ ! -d "$ASSETS" ]; then
    58	    echo "[80] WARN: NPU asset directory missing at $ASSETS"
    59	fi
    60	
    61	echo "[80] installing NCZ NPU stack (FyrbyAdditive MS-R1 fixes)..."
    62	
    63	# --- Step 1: install kernel modules ---
    64	# Two supported sources, in priority order:
    65	#   1. In-tree module shipped inside modules-cixmini.tgz (CONFIG_ARMCHINA_NPU=m).
    66	#      This is the case for the NEXT kernel (7.0.x-cix-sky1-next) where the
    67	#      driver is built as part of the kernel and already carries the correct
    68	#      vermagic. Nothing to copy — just confirm + depmod.
    69	#   2. Out-of-tree prebuilt $ASSETS/armchina_npu-${KVER}.ko, whose vermagic MUST
    70	#      exactly match $KVER. This is the case for the LTS kernel
    71	#      (6.18.26-ncz-lts), whose config does NOT enable CONFIG_ARMCHINA_NPU.
    72	for i in "${!KERNEL_VERS[@]}"; do
    73	    LABEL="${KERNEL_LABELS[$i]}"
    74	    KVER="${KERNEL_VERS[$i]}"
    75	    if [ ! -d "/usr/lib/modules/$KVER" ]; then
    76	        echo "[80] WARN: /usr/lib/modules/$KVER does not exist; skipping $KVER"
    77	        continue
    78	    fi
    79	
    80	    INTREE=$(find "/usr/lib/modules/$KVER/kernel" -name 'armchina_npu.ko*' 2>/dev/null | head -1)
    81	    SRC="$ASSETS/armchina_npu-${KVER}.ko"
    82	
    83	    if [ -n "$INTREE" ]; then
    84	        # In-tree build (NEXT): driver already present with matching vermagic.
    85	        depmod -a "$KVER" 2>/dev/null
    86	        echo "[80] $LABEL/$KVER: using in-tree armchina_npu.ko ($INTREE)"
    87	    elif [ -f "$SRC" ]; then
    88	        # Guard: refuse to install a vermagic-mismatched OOT module — loading it
    89	        # would either be rejected by modprobe or (with MODVERSIONS off) risk a
    90	        # silent ABI mismatch. Skip loudly instead.
    91	        VM=$(modinfo -F vermagic "$SRC" 2>/dev/null | awk '{print $1}')
    92	        if [ -n "$VM" ] && [ "$VM" != "$KVER" ]; then
    93	            echo "[80] ERROR: $SRC vermagic '$VM' != kernel '$KVER'; refusing to install (rebuild OOT module for $KVER)"
    94	            continue
    95	        fi
    96	        install -D -m 0644 "$SRC" "/usr/lib/modules/$KVER/extra/armchina_npu.ko"
    97	        depmod -a "$KVER" 2>/dev/null
    98	        echo "[80] $LABEL/$KVER: installed OOT armchina_npu.ko (vermagic $VM)"
    99	    else
   100	        echo "[80] WARN: no in-tree module and no $SRC; NPU unavailable for $LABEL/$KVER"
   101	    fi
   102	
   103	    # --- Overlay override (NCZ validated fixes, r104) ---
   104	    # The in-tree armchina_npu.ko in modules-cixmini.tgz may predate the
   105	    # ARCH_V3=y + iova_region=2 fixes (Zhouyi V3 detection / 32-bit-bus IOVA
   106	    # cap). A validated overlay installed to updates/ takes depmod precedence
   107	    # over kernel/, so the correct module loads even on an unrebuilt kernel.
   108	    OVERLAY=""
   109	    for cand in \
   110	        "/usr/local/lib/cix-installer/assets/kernel/modules-overlay/$KVER/armchina_npu.ko" \
   111	        "/cdrom/cixmini/assets/kernel/modules-overlay/$KVER/armchina_npu.ko"; do
   112	        [ -f "$cand" ] && { OVERLAY="$cand"; break; }
   113	    done
   114	    if [ -n "$OVERLAY" ]; then
   115	        OVM=$(modinfo -F vermagic "$OVERLAY" 2>/dev/null | awk '{print $1}')
   116	        if [ -n "$OVM" ] && [ "$OVM" != "$KVER" ]; then
   117	            echo "[80] WARN: overlay $OVERLAY vermagic '$OVM' != '$KVER'; not applying"
   118	        else
   119	            install -D -m 0644 "$OVERLAY" "/usr/lib/modules/$KVER/updates/armchina_npu.ko"
   120	            depmod -a "$KVER" 2>/dev/null
   121	            echo "[80] $LABEL/$KVER: applied validated NPU overlay (ARCH_V3+iova=2, vermagic $OVM) -> updates/"
   122	        fi
   123	    fi
   124	done
   125	
   126	# --- Step 2: ensure initrd exists for each NCZ kernel ---
   127	# 10-our-kernel.sh now generates initrds in the required phase. Keep this
   128	# fallback for older/rerun targets, but the boot-critical path no longer
   129	# depends on this optional hook.
   130	for KVER in "${KERNEL_VERS[@]}"; do
   131	    if [ -d "/usr/lib/modules/$KVER" ]; then
   132	        if [ ! -f "/boot/initrd.img-$KVER" ]; then
   133	            echo "[80] generating initrd for $KVER..."
   134	            update-initramfs -c -k "$KVER" 2>&1 | tail -5
   135	        else
   136	            echo "[80] initrd already present for $KVER"
   137	        fi
   138	    fi
   139	done
   140	
   141	# --- Step 3: ACPI SSDT override — BOARD-GATED (r123) ---
   142	#
   143	# The SSDT injects _HID="CIXH4010" onto the NPU compute cores (CRE0/CRE1/CRE2).
   144	# This is a fix for ONE specific defect: the Minisforum MS-R1's shipped BIOS
   145	# omits that _HID, so the cores never enumerate (CIXH4000:00 appears but no
   146	# CIXH4010:0x). On boards whose firmware is correct — Radxa Orion O6 / O6N —
   147	# the cores enumerate natively, and force-loading a second SSDT that redefines
   148	# the same ACPI named objects risks an AML name-collision (AE_ALREADY_EXISTS).
   149	# So we only prepend the override when the target actually needs it.
   150	#
   151	# Detection priority (runs in the d-i chroot, where /proc /sys /dev are
   152	# bind-mounted, so it reflects the REAL hardware being installed):
   153	#   0. operator override  /usr/local/lib/cix-installer/NPU_SSDT = force|skip
   154	#   1. functional ACPI check (authoritative, board-agnostic):
   155	#        >=3 CIXH4010:* cores present -> enumerate natively   -> SKIP
   156	#        CIXH4000:00 present, <3 cores -> MS-R1-class bug      -> APPLY
   157	#   2. DMI board match (only if ACPI gives no signal):
   158	#        MS-R1 / MINISFORUM -> APPLY ;  Radxa / Orion -> SKIP
   159	#   3. unknown + no CIX NPU ACPI signal -> SKIP + warn (refuse to inject an
   160	#        MS-R1 SSDT into unidentified hardware; a real MS-R1 would have matched
   161	#        step 1 or the MINISFORUM DMI rule). Override with NPU_SSDT=force.
   162	should_apply_npu_ssdt() {
   163	    local force="$INSTALLER_META/NPU_SSDT"
   164	    if [ -f "$force" ]; then
   165	        case "$(tr -d ' \t\r\n' < "$force" 2>/dev/null)" in
   166	            force|apply|on|1) echo "[80] NPU SSDT: forced ON by $force"; return 0 ;;
   167	            skip|off|0)       echo "[80] NPU SSDT: forced OFF by $force"; return 1 ;;
   168	        esac
   169	    fi
   170	
   171	    if [ -d /sys/bus/acpi/devices ]; then
   172	        # r124: require the FULL complement of cores before declaring firmware OK.
   173	        # A partial enumeration (1-2 of 3) is still a defect we should fix, so
   174	        # only >=3 CIXH4010:* cores count as "native".
   175	        local ncores
   176	        ncores=$(ls -d /sys/bus/acpi/devices/CIXH4010:* 2>/dev/null | wc -l)
   177	        if [ "$ncores" -ge 3 ]; then
   178	            echo "[80] NPU SSDT: $ncores CIXH4010:* cores enumerate natively (>=3) — SKIP (firmware OK; likely O6/O6N)"
   179	            return 1
   180	        fi
   181	        if [ -e /sys/bus/acpi/devices/CIXH4000:00 ]; then
   182	            echo "[80] NPU SSDT: NPU device present, cores incomplete ($ncores/3) — APPLY (MS-R1-class BIOS _HID gap)"
   183	            return 0
   184	        fi
   185	        echo "[80] NPU SSDT: no CIXH4000 in ACPI view — falling back to DMI board match"
   186	    else
   187	        echo "[80] NPU SSDT: /sys/bus/acpi unavailable in chroot — falling back to DMI board match"
   188	    fi
   189	
   190	    local pn pf sv
   191	    pn=$(cat /sys/class/dmi/id/product_name   2>/dev/null)
   192	    pf=$(cat /sys/class/dmi/id/product_family 2>/dev/null)
   193	    sv=$(cat /sys/class/dmi/id/sys_vendor     2>/dev/null)
   194	    case "$pn $pf $sv" in
   195	        *MS-R1*|*MINISFORUM*|*[Mm]inisforum*)
   196	            echo "[80] NPU SSDT: DMI='$pn'/'$pf' (Minisforum MS-R1) — APPLY"; return 0 ;;
   197	        *Orion*|*[Rr]adxa*)
   198	            echo "[80] NPU SSDT: DMI='$pn'/'$sv' (Radxa Orion) — SKIP (native _HID expected)"; return 1 ;;
   199	    esac
   200	
   201	    # r124: unknown board WITHOUT any CIX NPU ACPI signal -> SKIP, do NOT inject.
   202	    # If this were an MS-R1-class board the functional ACPI check above (or the
   203	    # MINISFORUM DMI match) would have already returned APPLY; reaching here
   204	    # means it is not recognizable CIX hardware, so injecting an MS-R1 SSDT is
   205	    # unsafe. Force it on a genuinely-MS-R1-class board with the override file.
   206	    echo "[80] NPU SSDT: board UNKNOWN (pn='$pn' pf='$pf' sv='$sv') and no CIX NPU ACPI signal — SKIP (refusing to inject MS-R1 SSDT into unidentified hardware)"
   207	    echo "[80]   (force on a known MS-R1-class board with: echo force > $INSTALLER_META/NPU_SSDT)"
   208	    return 1
   209	}
   210	
   211	# Prepend the 1024-byte SSDT CPIO archive to each kernel's initrd. The kernel
   212	# reads CPIO archives stacked before the main initramfs; the SSDT injects via
   213	# the ACPI override mechanism before any driver probes.
   214	if [ -f "$SSDT_CPIO" ] && should_apply_npu_ssdt; then
   215	    install -D -m 0644 "$SSDT_CPIO" /boot/npu-acpi-override.cpio
   216	    for KVER in "${KERNEL_VERS[@]}"; do
   217	        INITRD="/boot/initrd.img-$KVER"
   218	        if [ -f "$INITRD" ]; then
   219	            # Idempotent: only prepend if not already prepended (check first 4 bytes).
   220	            # CPIO archives start with "070701" (newc magic) — if initrd starts with
   221	            # those bytes we know it's already been prepended.
   222	            head -c 6 "$INITRD" 2>/dev/null | grep -q '070701' && {
   223	                echo "[80] $INITRD already has SSDT prepended, skipping"
   224	                continue
   225	            }
   226	            cp -n "$INITRD" "${INITRD}.pre-npu-override"
   227	            cat "$SSDT_CPIO" "${INITRD}.pre-npu-override" > "${INITRD}.tmp" \
   228	                && mv "${INITRD}.tmp" "$INITRD" \
   229	                && rm -f "${INITRD}.pre-npu-override" \
   230	                && echo "[80] SSDT override prepended to $INITRD"
   231	        else
   232	            echo "[80] WARN: $INITRD not found after update-initramfs; SSDT skipped for $KVER"
   233	        fi
   234	    done
   235	elif [ ! -f "$SSDT_CPIO" ]; then
   236	    echo "[80] WARN: SSDT CPIO missing at $SSDT_CPIO; NPU cores may not enumerate on MS-R1"
   237	else
   238	    echo "[80] NPU SSDT override staged but NOT applied for this board (see detection above)"
   239	fi
   240	
   241	# --- Step 4: auto-load on boot ---
   242	mkdir -p /etc/modules-load.d
   243	cat > /etc/modules-load.d/ncz-npu.conf << 'EOF'
   244	# NCZ 26.6: Cix Sky1 / Zhouyi v3 NPU driver
   245	# Probes CIXH4000:00 (\_SB_.NPU0) + CIXH4010:0[012] (3 cores via SSDT override)
   246	# Creates /dev/aipu chardev; inference via cix-noe-umd 2.0.2
   247	armchina_npu
   248	EOF
   249	
   250	# --- Step 5: drop NPU-STATUS.md ---
   251	mkdir -p /usr/share/doc/ncz
   252	cat > /usr/share/doc/ncz/NPU-STATUS.md << 'EOF'
   253	# NCZ 26.6 "Reinhardt" — Cix Sky1 / Zhouyi v3 NPU
   254	
   255	## What works
   256	
   257	- **Kernel module** `armchina_npu.ko` probes clean on MS-R1 for both NCZ kernels:
   258	  - 7.0.12-cix-sky1-next (default; in-tree CONFIG_ARMCHINA_NPU=m)
   259	  - 6.18.26-ncz-lts (stable fallback; out-of-tree module)
   260	- **ACPI SSDT override** corrects the missing `_HID="CIXH4010"` on NPU cores
   261	  (CRE0/CRE1/CRE2) — a bug in Minisforum's shipped BIOS omitted by the OEM.
   262	  Injected via initramfs CPIO prepend; fully reversible. **Board-gated (r123):**
   263	  applied only when the cores don't enumerate natively (MS-R1); skipped on
   264	  boards whose firmware is correct (Radxa Orion O6 / O6N) to avoid an AML
   265	  name-collision. Auto-detected at install; force with
   266	  `echo force|skip > /usr/local/lib/cix-installer/NPU_SSDT`.
   267	- **v0-compat ioctl handlers** bridge the struct-layout gap between
   268	  `cix-noe-umd 2.0.x` (k6.6 ABI) and the current kernel driver.
   269	- **SMMU 32-bit constraint** forces `bus_dma_limit=0xc0000000` and `dma_mask=32`;
   270	  without this the IOMMU hands out 35-bit IOVAs that the NPU's 32-bit address
   271	  bus truncates, causing SMMU faults on every memory access.
   272	- NPU enumeration after boot:
   273	  ```
   274	  /sys/bus/acpi/devices/CIXH4000:00    (NPU device)
   275	  /sys/bus/acpi/devices/CIXH4010:0[012]  (3 cores)
   276	  /dev/aipu                             (char device)
   277	  ```
   278	- **MobileNet V2 inference: ~640 inf/s (1.5 ms avg)** via `cix-noe-umd 2.0.2`
   279	  + pre-compiled `.cix` models from Cix AI Model Hub.
   280	
   281	## Installing the userspace runtime
   282	
   283	```bash
   284	# Install cix-noe-umd 2.0.2 (compatible with our v0-compat ioctl layer)
   285	curl -LO https://github.com/radxa-pkg/cix-prebuilt/releases/download/rc3.3-2601/cix-noe-umd_2.0.2_arm64.deb
   286	sudo dpkg -i cix-noe-umd_2.0.2_arm64.deb
   287	
   288	# Get pre-compiled .cix models
   289	sudo apt install -y python3-pip python3-numpy python3-pillow git git-lfs
   290	git lfs install
   291	git clone --depth 1 https://www.modelscope.cn/cix/ai_model_hub_25_Q3.git
   292	```
   293	
   294	## Running inference
   295	
   296	```bash
   297	cd ai_model_hub_25_Q3
   298	git lfs pull --include="models/ComputeVision/Image_Classification/onnx_mobilenet_v2/*"
   299	cd models/ComputeVision/Image_Classification/onnx_mobilenet_v2
   300	python3 run_onnx.py
   301	```
   302	
   303	Other available pre-compiled models: YOLOv8n, CLIP ViT-B/32, Whisper, ResNet50,
   304	SDXL-Turbo (see https://modelscope.cn/models/cix/ai_model_hub_25_Q3)
   305	
   306	## What's still open
   307	
   308	- **LLM on Zhouyi v3.** The Compass NN compiler is static-graph only —
   309	  transformer models with KV-cache / variable sequence length don't compile
   310	  cleanly. This is unsolved by anyone (Cix included). Vision models, audio
   311	  (Whisper), and image-gen all work via the Cix model hub.
   312	- **UMD 4.0.0 compat.** Only `cix-noe-umd 2.0.2` is confirmed working.
   313	
   314	## Credits
   315	
   316	- **FyrbyAdditive/ms-r1-npu-hack** — identified and fixed all four root causes
   317	  on MS-R1 (Armbian). NCZ integrates their patches into the installer.
   318	- **cixtech/cix_opensource__release__npu_driver** (`cix_mainline_dev`)
   319	- **radxa-pkg/cix-prebuilt** — `cix-noe-umd_2.0.2_arm64.deb`
   320	- **Cix AI Model Hub** on ModelScope — pre-compiled `.cix` inference graphs
   321	
   322	## References
   323	
   324	- [FyrbyAdditive/ms-r1-npu-hack](https://github.com/FyrbyAdditive/ms-r1-npu-hack)
   325	- [cixtech/cix_opensource__release__npu_driver](https://github.com/cixtech/cix_opensource__release__npu_driver)
   326	- [radxa-pkg/cix-prebuilt](https://github.com/radxa-pkg/cix-prebuilt)
   327	- [Cix AI Model Hub](https://www.modelscope.cn/cix/ai_model_hub_25_Q3)
   328	EOF
   329	chmod 0644 /usr/share/doc/ncz/NPU-STATUS.md
   330	
   331	# --- Step 5b: install the bundled operator docs (NPU embeddings, inference
   332	# limits/capability matrix, ModelScope model-pull guide). These are baked from
   333	# the repo docs/ via assets/docs/ (symlinks dereferenced at build time), so the
   334	# installed appliance carries the same reference material the repo ships. ---
   335	DOCS_SRC=/usr/local/lib/cix-installer/assets/docs
   336	if [ -d "$DOCS_SRC" ]; then
   337	    for d in "$DOCS_SRC"/*.md; do
   338	        [ -e "$d" ] || continue
   339	        install -m 0644 "$d" /usr/share/doc/ncz/ && \
   340	            echo "[80] doc: /usr/share/doc/ncz/$(basename "$d")"
   341	    done
   342	else
   343	    echo "[80] WARN: $DOCS_SRC not staged - operator docs not installed"
   344	fi
   345	
   346	
   347	# Marker for 70-bootloader.sh: NPU initrds need staging
   348	mkdir -p /var/lib/ncz
   349	: > /var/lib/ncz/npu-initrd-staging.list
   350	for KVER in "${KERNEL_VERS[@]}"; do
   351	    [ -f "/boot/initrd.img-$KVER" ] && echo "$KVER" >> /var/lib/ncz/npu-initrd-staging.list
   352	done
   353	
   354	echo "[80] NPU stack installed: modules + SSDT override + autoload + status doc"
   355	echo "[80] Install cix-noe-umd 2.0.2 from radxa-pkg/cix-prebuilt to enable inference"

