post-install/70-bootloader.sh:154:    echo "       Refusing to wipe the ESP because there is nothing bootable to restage."
post-install/70-bootloader.sh:160:# script, AFTER kernels/initrds are staged to the ESP and per-entry cmdlines
post-install/70-bootloader.sh:170:# `set -euo pipefail` aborted 70-bootloader -> run-all -> late.sh with the
post-install/70-bootloader.sh:191:# Cmdline (MartJohnson 2026-04-30 working set for MS-R1, both LTS+NEXT)
post-install/70-bootloader.sh:193:#   loglevel=4                          — visible kernel msgs through boot
post-install/70-bootloader.sh:198:#   audit_backlog_limit=8192            — early-boot audit subsystem doesn't drop msgs
post-install/70-bootloader.sh:200:#   keep_bootcon                        — early console persists through handoff
post-install/70-bootloader.sh:201:#   panic=30                            — 30s grace before reboot on panic
post-install/70-bootloader.sh:204:# so cmdline module_blacklist=armchina_npu is unnecessary. We don't
post-install/70-bootloader.sh:205:# add module blacklists here — the configs already disable everything
post-install/70-bootloader.sh:206:# that would cause boot trouble on MS-R1.
post-install/70-bootloader.sh:208:# r75 Codex round-5 HIGH fix — per-entry cmdline split.
post-install/70-bootloader.sh:210:# LTS keeps efi=noruntime (r74 ship stability; original MS-R1 EFI
post-install/70-bootloader.sh:211:# runtime quirk worked around by disabling it). NEXT drops it because
post-install/70-bootloader.sh:212:# systemd-bless-boot requires EFI runtime variables (LoaderBootCountPath)
post-install/70-bootloader.sh:213:# to mark a successful boot as good — without that, repeated successful
post-install/70-bootloader.sh:214:# NEXT boots burn the +N-M counter to .failed and roll back to LTS.
post-install/70-bootloader.sh:215:# linux-cix-sky1-next 7.0.x has newer EFI handling than the 6.6 fork
post-install/70-bootloader.sh:216:# the noruntime workaround was originally added for; defaulting to
post-install/70-bootloader.sh:217:# runtime-enabled on NEXT lets the auto-rollback semantics actually
post-install/70-bootloader.sh:219:# r123 (2026-06-22) boot speed + cleanliness fix:
post-install/70-bootloader.sh:221:#     MS-R1 when booting from disk (only the debug-harness exposes it). systemd
post-install/70-bootloader.sh:223:#     then blocks boot for the full 90s device timeout. Removing it cuts ~90s.
post-install/70-bootloader.sh:224:#   - DROPPED keep_bootcon — held the verbose early console through handoff,
post-install/70-bootloader.sh:226:#     to stable+edge for a clean graphical boot; rescue stays verbose.
post-install/70-bootloader.sh:227:#   - DROPPED loglevel — stable/edge get `quiet` (via SPLASH); rescue inherits
post-install/70-bootloader.sh:228:#     this base WITHOUT splash so it boots at the kernel-default verbose level.
post-install/70-bootloader.sh:229:LTS_CMDLINE_BASE="console=tty0 efi=noruntime acpi=force arm-smmu-v3.disable_bypass=0 audit_backlog_limit=8192 clk_ignore_unused panic=30 module_blacklist=typec_rts5453,rts5453"
post-install/70-bootloader.sh:230:# r105 boot-visibility fix (2026-06-17): NEXT (7.0.x) does NOT get an early
post-install/70-bootloader.sh:231:# framebuffer console like LTS does. With identical fb config, LTS's sysfb
post-install/70-bootloader.sh:232:# registers an efi-framebuffer device → efifb binds → colour console + boot
post-install/70-bootloader.sh:233:# penguins from ~1s. On 7.0.12, sysfb registers NO framebuffer device
post-install/70-bootloader.sh:234:# (screen_info isn't populated for it — a 7.0.x regression vs 6.18), so the
post-install/70-bootloader.sh:236:# — i.e. the whole early boot is invisible on HDMI.
post-install/70-bootloader.sh:238:#                     systemd-boot drew its menu on) from t=0, so early kernel
post-install/70-bootloader.sh:239:#                     messages are visible on the panel before the real KMS
post-install/70-bootloader.sh:240:#                     display comes up. keep_bootcon holds it through handoff.
post-install/70-bootloader.sh:241:#   loglevel=7      — show info-level boot messages (NOT ignore_loglevel,
post-install/70-bootloader.sh:243:# Verified on .66: early messages now render on HDMI from boot. The brief
post-install/70-bootloader.sh:244:# dark gap before the colour linlondp console is the SCMI display power-on
post-install/70-bootloader.sh:245:# latency and is not removable from cmdline (needs efifb to bind early —
post-install/70-bootloader.sh:248:# NEXT boot text visible on HDMI before KMS, but that is exactly the verbose
post-install/70-bootloader.sh:249:# "ugly" boot we now replace with the Plymouth splash. Early text is still
post-install/70-bootloader.sh:251:NEXT_CMDLINE_BASE="console=tty0 acpi=force arm-smmu-v3.disable_bypass=0 audit_backlog_limit=8192 clk_ignore_unused panic=30 module_blacklist=typec_rts5453,rts5453"
post-install/70-bootloader.sh:253:# Plymouth splash flags for a clean graphical boot. Appended to stable+edge
post-install/70-bootloader.sh:254:# only (see LTS_OPTIONS/NEXT_OPTIONS below) — rescue deliberately omits these
post-install/70-bootloader.sh:255:# so it stays text-verbose. 60-plymouth.sh sets the `nclawzero` default theme
post-install/70-bootloader.sh:257:# kernel flags. An optional /etc/kernel/cmdline.d/10-splash.conf overrides.
post-install/70-bootloader.sh:259:[ -f /etc/kernel/cmdline.d/10-splash.conf ] && SPLASH=$(cat /etc/kernel/cmdline.d/10-splash.conf)
post-install/70-bootloader.sh:275:# has proven /boot/efi is the vfat ESP, bootctl exists, and at least one
